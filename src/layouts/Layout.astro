---
import Footer from '@/components/Footer.astro';
import Navbar from '@/components/Navbar.astro';
import PageGrid from '@/components/PageGrid.astro';
import { SITE } from '@/config/site';
import '@/styles/starwind.css';
import { Font } from 'astro:assets';
import AstroSeo from '@/components/AstroSeo.astro';
import type { AstroSeoProps } from '@/types/seo';
import Analytics from '@/components/Analytics.astro';
import Contact1 from '@/blocks/contact/Contact1.astro';

Astro.response.headers.set('X-Robots-Tag', 'index, follow');

interface Props extends AstroSeoProps {
  /** Preload URL for the page LCP hero image (WebP). */
  lcpPreload?: string;
}

const { lcpPreload, ...seoProps } = Astro.props;
---

<!doctype html>
<html lang={SITE.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- SEO -->
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#7008e7" />
    <meta name="apple-mobile-web-app-title" content={SITE.businessShortName} />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />

    <!-- Apple -->
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- PWA -->
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Performance -->
    <Font cssVariable="--font-sans" preload />

    {
      lcpPreload && (
        <link
          rel="preload"
          as="image"
          href={lcpPreload}
          fetchpriority="high"
          type="image/webp"
        />
      )
    }

    <!-- SEO slots -->
    <slot name="head" />

    <AstroSeo
      noindex={false}
      nofollow={false}
      {...seoProps}
      additionalMetaTags={[
        ...(seoProps.additionalMetaTags || []),
        { name: 'publisher', content: SITE.author },
      ]}
    />
    <Analytics
      googleAnalyticsId={SITE.googleAnalyticsId}
      googleTagManagerId={SITE.googleTagManagerId}
    />
  </head>
  <body class="flex min-h-screen flex-col overflow-x-hidden bg-violet-50/30">
    <PageGrid />
    <Navbar />
    <main class="grow">
      <slot />
      <Contact1 />
    </main>
    <Footer />
  </body>
</html>
