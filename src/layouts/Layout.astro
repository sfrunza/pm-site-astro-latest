---
import Footer from '@/components/Footer.astro';
import Navbar from '@/components/Navbar.astro';
import MobileCallBar from '@/components/MobileCallBar.astro';
import PageGrid from '@/components/PageGrid.astro';
import { SITE } from '@/config/site';
import '@/styles/starwind.css';
import { Font } from 'astro:assets';
import AstroSeo from '@/seo/AstroSeo.astro';
import LcpPreloadLink from '@/components/LcpPreloadLink.astro';
import Analytics from '@/components/Analytics.astro';
import AttributionCapture from '@/components/AttributionCapture.astro';
import Contact1 from '@/blocks/contact/Contact1.astro';
import type { AstroSeoProps } from '@/seo';
import type { LcpPreloadLink as LcpPreloadData } from '@/utils/lcp-preload';
Astro.response.headers.set('X-Robots-Tag', 'index, follow');

interface Props extends AstroSeoProps {
  /** Hero LCP image preload — must be a direct Layout prop to land in `<head>`. */
  lcpPreload?: LcpPreloadData & { imagesizes?: string };
}

const { lcpPreload, ...seoProps } = Astro.props;
---

<!doctype html>
<html lang={SITE.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- SEO -->
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#7008e7" />
    <meta name="apple-mobile-web-app-title" content={SITE.businessShortName} />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />

    <!-- Apple -->
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- PWA -->
    <link rel="manifest" href="/site.webmanifest" />

    {
      lcpPreload && (
        <LcpPreloadLink
          href={lcpPreload.href}
          srcset={lcpPreload.srcset}
          type={lcpPreload.type}
          imagesizes={lcpPreload.imagesizes}
        />
      )
    }

    <!-- Performance: avoid font preload — it competes with the LCP image -->
    <Font cssVariable="--font-sans" />

    <!-- SEO slots -->
    <slot name="head" />

    <AstroSeo
      noindex={false}
      nofollow={false}
      {...seoProps}
      additionalMetaTags={[
        ...(seoProps.additionalMetaTags || []),
        { name: 'publisher', content: SITE.author },
      ]}
    />
    <Analytics
      googleAnalyticsId={SITE.googleAnalyticsId}
      googleTagManagerId={SITE.googleTagManagerId}
    />
    <AttributionCapture />
  </head>
  <body
    class="flex min-h-screen flex-col overflow-x-hidden bg-violet-50/30 pb-[calc(5.25rem+env(safe-area-inset-bottom))] lg:pb-0"
  >
    <PageGrid />
    <main class="grow">
      <slot />
      <Contact1 />
    </main>
    <Navbar />
    <Footer />
    <MobileCallBar />
  </body>
</html>
