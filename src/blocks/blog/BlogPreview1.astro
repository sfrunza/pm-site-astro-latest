---
import Section from '@/components/Section.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import Container from '@/components/Container.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import Button from '@/components/starwind/button';
import { ArrowRightIcon } from '@/icons';
import { getFeaturedPosts } from '@/config/blog';
import { tv } from 'tailwind-variants';
import { SITE } from '@/config/site';

interface Props {
  class?: string;
  limit?: number;
  label?: string;
  title?: string;
  subtitle?: string;
}

const blogPreview1 = tv({ base: '' });

const {
  class: className = '',
  limit = 3,
  label = 'From the Blog',
  title = 'Moving tips straight from the crew.',
  subtitle = `Field-tested advice from licensed ${SITE.businessShortName} crews — budgeting, packing, permits, and everything in between.`,
} = Astro.props;

const posts = (await getFeaturedPosts()).slice(0, limit);
---

<Section class={blogPreview1({ class: className })}>
  <Container>
    <div class="flex flex-col gap-10">
      <!-- Header row with inline CTA -->
      <div
        class="flex flex-col items-start gap-4 sm:flex-row sm:items-end sm:justify-between"
      >
        <SectionHeader
          label={label}
          title={title}
          subtitle={subtitle}
          position="left"
          class="mb-0"
        />
        <Button
          href="/blog"
          variant="primary"
          aria-label="Browse all moving guides and tips"
        >
          <ArrowRightIcon slot="icon" aria-hidden="true" />
          Browse All Articles
        </Button>
      </div>

      <!-- Post cards -->
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => <BlogCard post={post} />)}
      </div>

      <!-- Mobile-only full CTA -->
      <div class="flex justify-center sm:hidden">
        <Button
          href="/blog"
          variant="outline"
          aria-label="Browse all moving guides and tips"
        >
          <ArrowRightIcon slot="icon" aria-hidden="true" />
          Browse All Articles
        </Button>
      </div>
    </div>
  </Container>
</Section>
