---
import { ArrowRight, Receipt2Icon } from '@/icons';
import type { HTMLAttributes } from 'astro/types';
import { tv } from 'tailwind-variants';

import { Button } from '@/components/starwind/button';
import Section from '@/components/Section.astro';
import Container from '@/components/Container.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import RotatingGradientBorder from '@/components/RotatingGradientBorder.astro';
import { SITE } from '@/config/site';

export interface ButtonConfig {
  text: string;
  href: string;
}

interface Props extends HTMLAttributes<'section'> {
  /** Main heading text */
  title?: string;
  /** Description text */
  description?: string;
  /** Primary button configuration */
  primaryButton?: ButtonConfig;
  /** Secondary button configuration (optional) */
  secondaryButton?: ButtonConfig;
}

const cta2Styles = tv({
  base: '',
});

const {
  title = `Move with ${SITE.businessShortName} Boston.`,
  description = '',
  primaryButton = { text: 'Request Free Estimate Online', href: '/book' },
  secondaryButton,
  class: className,
  ...rest
} = Astro.props;
---

<Section class={cta2Styles({ class: className })} {...rest}>
  <Container>
    <RotatingGradientBorder class="rounded-3xl bg-card px-8 py-24 group/cta">
      <SectionHeader title={title} subtitle={description} />
      <div class="-mt-6 flex flex-col items-center">
        <p
          class="mb-8 inline-flex w-fit -rotate-1 items-center gap-2.5 rounded-lg border border-dashed border-primary/25 bg-background/60 px-4 py-2 text-sm text-muted-foreground shadow-[3px_3px_0_0] shadow-primary/10 backdrop-blur-xs transition-transform duration-300 group-hover/cta:rotate-0"
          aria-label="Pricing transparency guarantee"
        >
          <span
            class="bg-primary/10 text-primary flex size-7 shrink-0 items-center justify-center rounded-full"
            aria-hidden="true"
          >
            <Receipt2Icon class="size-4" />
          </span>
          <span>
            We never have
            <span class="text-foreground font-semibold"> hidden fees</span>
          </span>
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <Button
            variant="primary"
            aria-label={primaryButton.text}
            href={primaryButton.href}
          >
            {primaryButton.text}
          </Button>
          {
            secondaryButton && (
              <Button
                variant="outline"
                class="group"
                aria-label={secondaryButton.text}
                href={secondaryButton.href}
              >
                {secondaryButton.text}
                <ArrowRight class="transition-transform group-hover:translate-x-1" />
              </Button>
            )
          }
        </div>
      </div>
    </RotatingGradientBorder>
  </Container>
</Section>
