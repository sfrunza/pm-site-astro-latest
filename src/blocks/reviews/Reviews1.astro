---
import Container from '@/components/Container.astro';
import Section from '@/components/Section.astro';
import Button from '@/components/starwind/button';
import { tv } from 'tailwind-variants';
import { ExternalLinkIcon } from '@/icons';
import MouseRepelParticles from '@/components/MouseRepelParticles.astro';
import { getGoogleReviews, getYelpReviews } from '@/lib/google-reviews';
import SectionHeader from '@/components/SectionHeader.astro';
import Image from 'astro/components/Image.astro';

interface Props {
  title?: string;
  subtitle?: string;
  placeId?: string;
  googleMapsUrl?: string;
  yelpBusinessIdOrAlias?: string;
  yelpUrl?: string;
  class?: string;
}

type ReviewSource = 'google' | 'yelp';

interface DisplayReview {
  source: ReviewSource;
  authorName: string;
  authorUrl: string;
  profilePhotoUrl: string;
  rating: number;
  relativeTime: string;
  text: string;
  reviewUrl: string;
  sortTime: number;
}

const {
  title = 'What Our Customers Say',
  subtitle = 'Read reviews from our satisfied customers',
  placeId = import.meta.env.PUBLIC_GOOGLE_PLACE_ID,
  googleMapsUrl,
  yelpBusinessIdOrAlias = import.meta.env.YELP_BUSINESS_ID ??
    import.meta.env.PUBLIC_YELP_BUSINESS_ID ??
    'phoenix-moving-natick-6',
  yelpUrl = 'https://www.yelp.com/biz/phoenix-moving-natick-6',
  class: className = '',
} = Astro.props;

const googleApiKey = import.meta.env.PUBLIC_GOOGLE_PLACES_API_KEY;
const yelpApiKey =
  import.meta.env.YELP_API_KEY ?? import.meta.env.PUBLIC_YELP_API_KEY;

const [googleData, yelpData] = await Promise.all([
  getGoogleReviews({ placeId, googleMapsUrl }),
  getYelpReviews({ businessIdOrAlias: yelpBusinessIdOrAlias, yelpUrl }),
]);

const googleReviews: DisplayReview[] = googleData.reviews.map((review) => ({
  source: 'google',
  authorName: review.author_name,
  authorUrl: review.author_url,
  profilePhotoUrl: review.profile_photo_url,
  rating: review.rating,
  relativeTime: review.relative_time_description,
  text: review.text,
  reviewUrl: review.author_url,
  sortTime: review.time,
}));

const yelpReviews: DisplayReview[] = yelpData.reviews.map((review) => ({
  source: 'yelp',
  authorName: review.user.name,
  authorUrl: review.user.profile_url,
  profilePhotoUrl: review.user.image_url,
  rating: review.rating,
  relativeTime: review.relative_time_description,
  text: review.text,
  reviewUrl: review.url,
  sortTime: new Date(review.time_created.replace(' ', 'T')).getTime() / 1000,
}));

const reviews = [...googleReviews, ...yelpReviews].sort(
  (a, b) => b.sortTime - a.sortTime
);

const googleWeight = googleData.totalReviews > 0 ? googleData.totalReviews : 0;
const yelpWeight = yelpData.totalReviews > 0 ? yelpData.totalReviews : 0;
const totalReviews = googleWeight + yelpWeight;
const averageRating =
  totalReviews > 0
    ? (googleData.averageRating * googleWeight +
        yelpData.averageRating * yelpWeight) /
      totalReviews
    : 0;

const hasGoogleConfig = Boolean(googleApiKey && placeId);
const hasYelpConfig = Boolean(yelpApiKey && yelpBusinessIdOrAlias);

const renderStars = (rating: number) => {
  return Array.from({ length: 5 }, (_, i) => i < rating);
};

const reviews1 = tv({
  base: 'bg-muted/50 relative isolate overflow-hidden',
});
---

<Section class={reviews1({ class: className })}>
  <MouseRepelParticles />
  <Container>
    <SectionHeader label="Reviews" title={title} subtitle={subtitle} />
    <div class="text-center mb-12">
      {
        averageRating > 0 && (
          <div class="flex items-center justify-center gap-4 mb-6">
            <div class="flex items-center gap-2">
              <div class="flex items-center gap-1">
                {renderStars(Math.round(averageRating)).map((filled) => (
                  <svg
                    class={`size-6 ${filled ? 'fill-yellow-400 text-yellow-400' : 'text-gray-300'}`}
                    viewBox="0 0 24 24"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                  </svg>
                ))}
              </div>
              <span class="text-2xl font-bold">{averageRating.toFixed(1)}</span>
            </div>
            <span class="text-muted-foreground">
              Based on {totalReviews} reviews
            </span>
          </div>
        )
      }
    </div>

    {
      reviews.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
          {reviews.map((review) => (
            <article class="bg-card relative text-card-foreground ring-border flex flex-col rounded-3xl ring-1 p-5">
              <div class="absolute top-4 right-4">
                {review.source === 'google' ? (
                  <svg class="size-8" viewBox="0 0 24 24" aria-hidden="true">
                    <path
                      fill="#4285F4"
                      d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                    />
                    <path
                      fill="#34A853"
                      d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                    />
                    <path
                      fill="#FBBC05"
                      d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                    />
                    <path
                      fill="#EA4335"
                      d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                    />
                  </svg>
                ) : (
                  <svg
                    class="size-8 text-[#D32323]"
                    viewBox="0 0 926.7 1220"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d="M23.6 587.4C3.8 619.1-4.5 718.8 2.4 784.9c2.4 21.8 6.4 40 12.1 50.9 7.9 15 21.2 24 36.3 24.5 9.7.5 15.8-1.2 198.3-59.9 0 0 81.1-25.9 81.5-26.1 20.2-5.2 33.9-23.8 35.2-47.5 1.3-24.4-11.2-45.9-32-53.6 0 0-57.2-23.3-57.3-23.3-196.2-80.9-205-84.1-214.9-84.2-15.2-.5-28.6 7.1-38 21.7m438.8 602.9c3.2-9.2 3.6-15.5 4.1-207.3 0 0 .4-84.7.5-85.6 1.3-20.8-12.1-39.7-34.1-48.2-22.7-8.7-47.1-3.3-60.8 13.7 0 0-40 47.5-40.2 47.5-137.4 161.4-143.2 168.9-146.5 178.4-2.1 5.6-2.8 11.6-2.2 17.6.8 8.6 4.7 17 11.1 24.9 31.9 37.9 184.7 94.1 233.5 85.7 17.1-2.9 29.4-12.4 34.6-26.7m310.1-66.7c46.1-18.4 146.6-146.2 153.7-195.5 2.5-17.1-2.9-31.9-14.7-41.3-7.7-5.8-13.6-8.1-196.1-68 0 0-80-26.4-81.1-26.9-19.4-7.5-41.5-.5-56.3 17.8-15.5 18.8-17.8 43.7-5.4 62.4l32.2 52.4c108.3 175.9 116.6 188.3 124.4 194.4 12 9.5 27.3 11.1 43.3 4.7m-94.3-452.8c207.3-50.2 215.4-52.9 223.5-58.3 12.6-8.5 18.9-22.6 17.8-39.8 0-.5.1-1.1 0-1.7-5.3-51-94.5-183.4-138.5-204.9-15.6-7.5-31.2-7-44.1 1.7-8 5.2-13.9 13.1-124.9 165 0 0-50.1 68.3-50.7 69-13.2 16.1-13.4 39.1-.5 58.9 13.4 20.5 36 30.4 56.7 24.7 0 0-.8 1.5-1 1.7 10.2-3.9 28.4-8.4 61.7-16.3M470.1 499.6c-3.6-82.2-28.3-448.1-31.2-465-4.2-15.4-16.2-26.3-33.4-30.7-53-13.1-255.3 43.6-292.8 82.2-12.1 12.6-16.5 28-12.9 41.7 5.9 12.1 256.6 406.5 256.6 406.5 37 60.1 67.3 50.7 77.2 47.6 9.8-2.9 39.9-12.3 36.5-82.3" />
                  </svg>
                )}
              </div>
              <div class="flex items-start gap-3 mb-3">
                {review.profilePhotoUrl ? (
                  <Image
                    width={40}
                    height={40}
                    src={review.profilePhotoUrl}
                    alt={review.authorName}
                    title={review.authorName}
                    class="rounded-full object-cover shrink-0 size-10"
                    loading="lazy"
                    decoding="async"
                    fetchpriority="low"
                    quality={50}
                  />
                ) : (
                  <div
                    class="rounded-full bg-muted text-muted-foreground shrink-0 size-10 flex items-center justify-center text-sm font-semibold"
                    aria-hidden="true"
                  >
                    {review.authorName.charAt(0)}
                  </div>
                )}
                <div class="flex-1 min-w-0">
                  <h3
                    class="font-semibold text-sm truncate"
                    aria-label={review.authorName}
                  >
                    {review.authorName}
                  </h3>
                  <p class="text-xs text-muted-foreground">
                    {review.relativeTime}
                  </p>
                </div>
              </div>

              <div class="flex items-center gap-1 mb-3">
                {renderStars(review.rating).map((filled) => (
                  <svg
                    class={`size-5 ${filled ? 'fill-yellow-400 text-yellow-400' : 'text-gray-300'}`}
                    viewBox="0 0 24 24"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                  </svg>
                ))}
              </div>

              <div class="relative mb-3 flex-1">
                <p class="text-sm text-muted-foreground leading-relaxed line-clamp-6">
                  {review.text}
                </p>
                <div class="absolute bottom-0 left-0 right-0 h-12 bg-linear-to-t from-card via-card/50 to-transparent pointer-events-none" />
              </div>

              <Button
                href={review.reviewUrl}
                aria-label={`View ${review.authorName} on ${review.source === 'google' ? 'Google' : 'Yelp'}`}
                target="_blank"
                rel="noopener noreferrer"
                size="sm"
                variant="error"
                class={[
                  'w-fit ml-auto',
                  review.source === 'google'
                    ? 'bg-cyan-600 text-white hover:bg-cyan-500'
                    : 'bg-red-600 text-white hover:bg-red-500',
                ].join(' ')}
              >
                {/* class="text-xs group text-primary hover:underline inline-flex items-center gap-1 mt-auto font-medium" */}
                <ExternalLinkIcon
                  slot="icon"
                  aria-hidden="true"
                  class="size-3.5"
                />
                View on {review.source === 'google' ? 'Google' : 'Yelp'}
              </Button>
            </article>
          ))}
        </div>
      ) : (
        <div class="text-center py-12">
          <p class="text-muted-foreground mb-4">
            {hasGoogleConfig || hasYelpConfig
              ? 'No reviews available yet.'
              : 'Configure Google Places or Yelp API credentials to display reviews.'}
          </p>
        </div>
      )
    }

    {
      (googleData.reviewsUrl || yelpData.reviewsUrl) && (
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          {googleData.reviewsUrl && (
            <Button
              href={googleData.reviewsUrl}
              aria-label="View All Reviews on Google"
              target="_blank"
              rel="noopener noreferrer"
              size="lg"
              variant="outline"
            >
              <ExternalLinkIcon slot="icon" aria-hidden="true" />
              View All on Google
            </Button>
          )}
          {yelpData.reviewsUrl && (
            <Button
              href={yelpData.reviewsUrl}
              aria-label="View All Reviews on Yelp"
              target="_blank"
              rel="noopener noreferrer"
              size="lg"
              variant="outline"
            >
              <ExternalLinkIcon slot="icon" aria-hidden="true" />
              View All on Yelp
            </Button>
          )}
        </div>
      )
    }
  </Container>
</Section>
