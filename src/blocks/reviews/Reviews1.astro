---
import Container from '@/components/Container.astro';
import Section from '@/components/Section.astro';
import Button from '@/components/starwind/button';
import { tv } from 'tailwind-variants';
import { ExternalLinkIcon } from '@/icons';
import MouseRepelParticles from '@/components/MouseRepelParticles.astro';
import { getGoogleReviews } from '@/lib/google-reviews';

interface Props {
  title?: string;
  subtitle?: string;
  placeId?: string;
  googleMapsUrl?: string;
  class?: string;
}

const {
  title = 'What Our Customers Say',
  subtitle = 'Read reviews from our satisfied customers',
  placeId = import.meta.env.PUBLIC_GOOGLE_PLACE_ID,
  googleMapsUrl,
  class: className = '',
} = Astro.props;

const apiKey = import.meta.env.PUBLIC_GOOGLE_PLACES_API_KEY;
const { reviews, averageRating, totalReviews, reviewsUrl } =
  await getGoogleReviews({ placeId, googleMapsUrl });

// Helper function to render stars
const renderStars = (rating: number) => {
  return Array.from({ length: 5 }, (_, i) => i < rating);
};

const reviews1 = tv({
  base: 'py-16 bg-muted/50 relative isolate overflow-hidden',
});
---

<Section class={reviews1({ class: className })}>
  <MouseRepelParticles />
  <Container>
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4">
        {title}
      </h2>
      <p class="text-lg text-muted-foreground mb-6 max-w-2xl mx-auto">
        {subtitle}
      </p>

      {
        averageRating > 0 && (
          <div class="flex items-center justify-center gap-4 mb-6">
            <div class="flex items-center gap-2">
              <div class="flex items-center gap-1">
                {renderStars(Math.round(averageRating)).map((filled) => (
                  <svg
                    class={`size-6 ${filled ? 'fill-yellow-400 text-yellow-400' : 'text-gray-300'}`}
                    viewBox="0 0 24 24"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                  </svg>
                ))}
              </div>
              <span class="text-2xl font-bold">{averageRating.toFixed(1)}</span>
            </div>
            <span class="text-muted-foreground">
              Based on {totalReviews} reviews
            </span>
          </div>
        )
      }
    </div>

    {
      reviews.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
          {reviews.map((review) => (
            <article class="bg-card text-card-foreground ring-border flex flex-col rounded-3xl ring-1 p-5">
              <div class="flex items-start gap-3 mb-3">
                <img
                  src={review.profile_photo_url}
                  alt={review.author_name}
                  class="size-10 rounded-full object-cover shrink-0"
                  loading="lazy"
                />
                <div class="flex-1 min-w-0">
                  <h3 class="font-semibold text-sm truncate">
                    {review.author_name}
                  </h3>
                  <p class="text-xs text-muted-foreground">
                    {review.relative_time_description}
                  </p>
                </div>
              </div>

              <div class="flex items-center gap-1 mb-3">
                {renderStars(review.rating).map((filled) => (
                  <svg
                    class={`size-3.5 ${filled ? 'fill-yellow-400 text-yellow-400' : 'text-gray-300'}`}
                    viewBox="0 0 24 24"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                  </svg>
                ))}
              </div>

              <div class="relative mb-3">
                <p class="text-sm text-muted-foreground leading-relaxed line-clamp-10">
                  {review.text}
                </p>
                <div class="absolute bottom-0 left-0 right-0 h-12 bg-linear-to-t from-card via-card/80 to-transparent pointer-events-none" />
              </div>

              <a
                href={review.author_url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-xs group text-primary hover:underline inline-flex items-center gap-1 mt-auto font-medium"
              >
                View on Google
                <ExternalLinkIcon class="transition-transform group-hover:translate-x-1 size-3.5" />
              </a>
            </article>
          ))}
        </div>
      ) : (
        <div class="text-center py-12">
          <p class="text-muted-foreground mb-4">
            {apiKey && placeId
              ? 'Loading reviews...'
              : 'Configure your Google Places API key and Place ID to display reviews.'}
          </p>
        </div>
      )
    }

    {
      reviewsUrl && (
        <div class="text-center">
          <Button
            href={reviewsUrl}
            target="_blank"
            rel="noopener noreferrer"
            variant="primary"
            size="lg"
            class="group"
          >
            {/* class="inline-flex items-center gap-2 px-8 py-3 bg-primary text-primary-foreground rounded-lg font-semibold hover:bg-primary/90 transition-colors duration-200 shadow-md hover:shadow-lg" */}
            View All Reviews on Google
            <ExternalLinkIcon class="transition-transform group-hover:translate-x-1" />
          </Button>
        </div>
      )
    }
  </Container>
</Section>
