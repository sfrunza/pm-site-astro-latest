---
import Section from '@/components/Section.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import { cities } from '@/config/cities-data';
import { getPremiumCityLinks } from '@/config/city-premium/registry';
import { MapPinIcon, PhoneIcon } from '@/icons';
import Container from '@/components/Container.astro';
import { tv } from 'tailwind-variants';
import { SITE } from '@/config/site';
import Button from '@/components/starwind/button';

interface Props {
  class?: string;
  /** Omit self-link when embedded on a city page (e.g. `cambridge-movers`). */
  currentSlug?: string;
}

const cities1 = tv({
  base: '',
});

const { class: className = '', currentSlug } = Astro.props;

const SERVICE_AREAS_HEADING_ID = 'service-areas-heading';

const subsectionHeadingClass =
  'text-xs font-semibold uppercase tracking-widest text-muted-foreground';

const normalizeSlug = (slug: string) => slug.replace(/^\//, '');

const activeSlug = currentSlug ? normalizeSlug(currentSlug) : '';

const maCities = cities
  .filter((c) => c.state === 'MA')
  .filter((c) => !activeSlug || c.slug !== activeSlug)
  .sort((a, b) => a.name.localeCompare(b.name));

const outOfStateCities = cities
  .filter((c) => c.state !== 'MA')
  .filter((c) => !activeSlug || c.slug !== activeSlug)
  .sort((a, b) => a.name.localeCompare(b.name));

const premiumCityLinks = getPremiumCityLinks().filter(
  (city) => !activeSlug || normalizeSlug(city.href) !== activeSlug
);
const phoneHref = `tel:${SITE.contactPhone}`;
---

<Section
  class={cities1({ class: className })}
  aria-labelledby={SERVICE_AREAS_HEADING_ID}
>
  <Container>
    <div
      class="rounded-3xl border border-border/40 bg-linear-to-br from-muted/20 to-muted/50 px-6 py-16 md:px-12 md:py-20"
    >
      <SectionHeader
        label={`${cities.length}+ Service Locations`}
        title="Areas We Proudly Serve with Excellence"
        titleId={SERVICE_AREAS_HEADING_ID}
        subtitle={`From our Natick home base, ${SITE.businessShortName} dispatches licensed, insured crews to cities and towns across Greater Boston, MetroWest, the North Shore, South Shore, Cape Cod, and neighboring states.`}
      />

      {
        premiumCityLinks.length > 0 && (
          <nav aria-label="Featured city moving guides" class="mb-10">
            <div class="mb-3 flex items-center gap-3">
              <MapPinIcon
                class="size-4 shrink-0 text-primary"
                aria-hidden="true"
              />
              <h3
                class={subsectionHeadingClass}
                aria-label="Featured City Guides"
              >
                Featured City Guides
              </h3>
              <div class="h-px flex-1 bg-border/60" aria-hidden="true" />
              <span class="text-xs text-muted-foreground">
                {premiumCityLinks.length} full guides
              </span>
            </div>

            <ul role="list" class="grid grid-cols-2 gap-2 sm:grid-cols-4">
              {premiumCityLinks.map((city) => (
                <li role="listitem">
                  <a
                    href={city.href}
                    aria-label={`${city.label} — local moving guide`}
                    title={`${city.label} — local moving guide`}
                    class="group flex flex-col gap-1 rounded-xl border border-primary/25 bg-primary/5 px-4 py-3 text-sm transition-all duration-150 hover:border-primary/40 hover:bg-primary/10 hover:shadow-sm"
                  >
                    <span class="font-semibold text-foreground transition-transform duration-150 group-hover:translate-x-0.5">
                      {city.cityName} movers
                    </span>
                    <span class="text-xs text-muted-foreground">
                      Full moving guide
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        )
      }

      <nav aria-label="Massachusetts moving service areas" class="mb-10">
        <div class="mb-3 flex items-center gap-3">
          <MapPinIcon class="size-4 shrink-0 text-primary" aria-hidden="true" />
          <h3 class={subsectionHeadingClass} aria-label="Massachusetts">
            Massachusetts
          </h3>
          <div class="h-px flex-1 bg-border/60" aria-hidden="true"></div>
          <span class="text-xs text-muted-foreground">
            {maCities.length} cities &amp; towns
          </span>
        </div>

        <ul
          role="list"
          class="grid grid-cols-2 gap-1.5 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6"
        >
          {
            maCities.map((city) => (
              <li role="listitem">
                <a
                  href={`/${city.slug}`}
                  aria-label={`Moving services in ${city.name}, MA`}
                  title={`Moving services in ${city.name}, MA`}
                  class="group flex items-center gap-2 rounded-lg border border-transparent px-3 py-2.5 text-sm text-muted-foreground transition-all duration-150 hover:border-primary/20 hover:bg-primary/5 hover:text-foreground"
                >
                  <span
                    class="size-1.5 shrink-0 rounded-full bg-primary/30 transition-colors duration-150 group-hover:bg-primary"
                    aria-hidden="true"
                  />
                  <span class="transition-transform duration-150 group-hover:translate-x-0.5">
                    {city.name} movers
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      {
        outOfStateCities.length > 0 && (
          <nav aria-label="Out-of-state moving destinations" class="mb-10">
            <div class="mb-3 flex items-center gap-3">
              <MapPinIcon
                class="size-4 shrink-0 text-muted-foreground/60"
                aria-hidden="true"
              />
              <h3 class={subsectionHeadingClass} aria-label="Out of State">
                Out of State
              </h3>
              <div class="h-px flex-1 bg-border/60" aria-hidden="true" />
              <span class="text-xs text-muted-foreground">
                {outOfStateCities.length} destinations
              </span>
            </div>

            <ul
              role="list"
              class="grid grid-cols-2 gap-1.5 sm:grid-cols-3 md:grid-cols-4"
            >
              {outOfStateCities.map((city) => (
                <li role="listitem">
                  <a
                    href={`/${city.slug}`}
                    aria-label={`Moving services in ${city.name}, ${city.state}`}
                    title={`Moving services in ${city.name}, ${city.state}`}
                    class="group flex items-center gap-2 rounded-lg border border-transparent px-3 py-2.5 text-sm text-muted-foreground transition-all duration-150 hover:border-border hover:bg-muted hover:text-foreground"
                  >
                    <span
                      class="size-1.5 shrink-0 rounded-full bg-muted-foreground/25 transition-colors duration-150 group-hover:bg-muted-foreground/60"
                      aria-hidden="true"
                    />
                    <span class="transition-transform duration-150 group-hover:translate-x-0.5">
                      {city.name}, {city.state} movers
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        )
      }

      <div
        class="flex flex-col items-start gap-4 justify-between rounded-2xl border border-dashed bg-background/60 px-6 py-5 sm:flex-row sm:items-center"
      >
        <div class="flex items-start gap-3 sm:items-center">
          <MapPinIcon
            class="mt-0.5 size-5 shrink-0 text-primary sm:mt-0"
            aria-hidden="true"
          />
          <p class="text-sm text-muted-foreground">
            <strong class="font-semibold text-foreground"
              >Don't see your city?</strong
            >
            {' '}We likely still cover your area — call us and we'll confirm.
          </p>
        </div>
        <Button
          href={phoneHref}
          aria-label={`Call ${SITE.businessName} at ${SITE.contactPhone}`}
          variant="primary"
          size="sm"
        >
          <PhoneIcon slot="icon" aria-hidden="true" />
          {SITE.contactPhone}
        </Button>
      </div>
    </div>
  </Container>
</Section>
