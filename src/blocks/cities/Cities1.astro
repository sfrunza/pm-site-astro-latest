---
import Section from '@/components/Section.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import { cities } from '@/config/cities-data';
import { getPremiumCityLinks } from '@/config/city-premium/registry';
import { MapPinIcon, PhoneIcon } from '@/icons';
import Container from '@/components/Container.astro';
import { tv } from 'tailwind-variants';
import { SITE } from '@/config/site';
import Button from '@/components/starwind/button';

interface Props {
  class?: string;
}

const cities1 = tv({
  base: '',
});

const { class: className = '' } = Astro.props;

const maCities = cities
  .filter((c) => c.state === 'MA')
  .sort((a, b) => a.name.localeCompare(b.name));

const outOfStateCities = cities
  .filter((c) => c.state !== 'MA')
  .sort((a, b) => a.name.localeCompare(b.name));

const premiumCityLinks = getPremiumCityLinks();
const phoneHref = `tel:${SITE.contactPhone}`;
---

<Section class={cities1({ class: className })}>
  <Container>
    <div
      class="rounded-3xl border border-border/40 bg-linear-to-br from-muted/20 to-muted/50 px-6 py-16 md:px-12 md:py-20"
    >
      <SectionHeader
        label={`${cities.length}+ Service Locations`}
        title="Areas We Proudly Serve with Excellence"
        subtitle=`From our Natick home base, ${SITE.businessShortName} dispatches licensed, insured crews to cities and towns across Greater Boston, MetroWest, the North Shore, South Shore, Cape Cod, and neighboring states.`
      />

      {
        premiumCityLinks.length > 0 && (
          <>
            <div class="mb-3 flex items-center gap-3">
              <MapPinIcon class="size-4 shrink-0 text-primary" />
              <span class="text-xs font-semibold uppercase tracking-widest text-muted-foreground">
                Featured City Guides
              </span>
              <div class="h-px flex-1 bg-border/60" />
              <span class="text-xs text-muted-foreground">
                {premiumCityLinks.length} full guides
              </span>
            </div>

            <div class="mb-10 grid grid-cols-2 gap-2 sm:grid-cols-4">
              {premiumCityLinks.map((city) => (
                <a
                  href={city.href}
                  title={`${city.label} — local moving guide`}
                  aria-label={`${city.label} — ${SITE.businessShortName}`}
                  class="group flex flex-col gap-1 rounded-xl border border-primary/25 bg-primary/5 px-4 py-3 text-sm transition-all duration-150 hover:border-primary/40 hover:bg-primary/10 hover:shadow-sm"
                >
                  <span class="font-semibold text-foreground transition-transform duration-150 group-hover:translate-x-0.5">
                    {city.cityName}
                  </span>
                  <span class="text-xs text-muted-foreground">Full moving guide</span>
                </a>
              ))}
            </div>
          </>
        )
      }

      <!-- Massachusetts cities -->
      <div class="mb-3 flex items-center gap-3">
        <MapPinIcon class="size-4 shrink-0 text-primary" />
        <span
          class="text-xs font-semibold uppercase tracking-widest text-muted-foreground"
        >
          Massachusetts
        </span>
        <div class="h-px flex-1 bg-border/60"></div>
        <span class="text-xs text-muted-foreground"
          >{maCities.length} cities &amp; towns</span
        >
      </div>

      <div
        class="mb-10 grid grid-cols-2 gap-1.5 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6"
      >
        {
          maCities.map((city) => (
            <a
              href={`/${city.slug}`}
              title={`Moving services in ${city.name}, MA`}
              aria-label={`${city.name} movers — ${SITE.businessShortName}`}
              class="group flex items-center gap-2 rounded-lg border border-transparent px-3 py-2.5 text-sm text-muted-foreground transition-all duration-150 hover:border-primary/20 hover:bg-primary/5 hover:text-foreground"
            >
              <span class="size-1.5 shrink-0 rounded-full bg-primary/30 transition-colors duration-150 group-hover:bg-primary" />
              <span class="transition-transform duration-150 group-hover:translate-x-0.5">
                {city.name}
              </span>
            </a>
          ))
        }
      </div>

      <!-- Out-of-state cities -->
      {
        outOfStateCities.length > 0 && (
          <>
            <div class="mb-3 flex items-center gap-3">
              <MapPinIcon class="size-4 shrink-0 text-muted-foreground/60" />
              <span class="text-xs font-semibold uppercase tracking-widest text-muted-foreground">
                Out of State
              </span>
              <div class="h-px flex-1 bg-border/60" />
              <span class="text-xs text-muted-foreground">
                {outOfStateCities.length} destinations
              </span>
            </div>

            <div class="mb-10 grid grid-cols-2 gap-1.5 sm:grid-cols-3 md:grid-cols-4">
              {outOfStateCities.map((city) => (
                <a
                  href={`/${city.slug}`}
                  title={`Moving services in ${city.name}, ${city.state}`}
                  aria-label={`${city.name} movers — ${SITE.businessShortName}`}
                  class="group flex items-center gap-2 rounded-lg border border-transparent px-3 py-2.5 text-sm text-muted-foreground transition-all duration-150 hover:border-border hover:bg-muted hover:text-foreground"
                >
                  <span class="size-1.5 shrink-0 rounded-full bg-muted-foreground/25 transition-colors duration-150 group-hover:bg-muted-foreground/60" />
                  <span class="transition-transform duration-150 group-hover:translate-x-0.5">
                    {city.name},&nbsp;{city.state}
                  </span>
                </a>
              ))}
            </div>
          </>
        )
      }

      <!-- "Don't see your city?" CTA strip -->
      <div
        class="flex flex-col items-start gap-4 justify-between rounded-2xl border border-dashed border-border bg-background/60 px-6 py-5 sm:flex-row sm:items-center"
      >
        <div class="flex items-start gap-3 sm:items-center">
          <MapPinIcon class="mt-0.5 size-5 shrink-0 text-primary sm:mt-0" />
          <p class="text-sm text-muted-foreground">
            <strong class="font-semibold text-foreground"
              >Don't see your city?</strong
            >
            {' '}We likely still cover your area — call us and we'll confirm.
          </p>
        </div>
        <Button
          href={phoneHref}
          aria-label={`Call ${SITE.businessName} at ${SITE.contactPhone}`}
          variant="primary"
          size="sm"
        >
          <PhoneIcon slot="icon" aria-hidden="true" />
          {SITE.contactPhone}
        </Button>
      </div>
    </div>
  </Container>
</Section>
