---
import {
  Card,
  CardHeader,
  CardTitle,
  CardDescription,
  CardContent,
} from '@/components/starwind/card';
import { Button } from '@/components/starwind/button';
import { SITE } from '@/config/site';
import { PhoneIcon, CircleCheckIcon } from '@/icons';
import Section from '@/components/Section.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import Container from '@/components/Container.astro';
import { tv } from 'tailwind-variants';
import RotatingGradientBorder from '@/components/RotatingGradientBorder.astro';

const PRICES_API_URL = 'https://account.gophoenixmoving.com/api/v1/prices';

type Price = {
  two_men: [number, number];
  three_men: [number, number];
  four_men: [number, number];
  add_men: [number, number];
  add_truck: [number, number];
};

type PriceKey = keyof Price;

type Tier = {
  name: string;
  href: string;
  priceMonthly: number;
  priceKey: PriceKey;
  description: string;
  sizes: string;
  includedFeatures: string[];
  isPopular?: boolean;
};

const prices: Price[] = await fetch(PRICES_API_URL).then((res) => res.json());

const tiers: Tier[] = [
  {
    name: '2 Movers',
    href: '/book',
    priceMonthly: prices?.[0]?.two_men[0] ?? 0,
    priceKey: 'two_men',
    description: 'Starting from',
    sizes: 'Room/Studio',
    includedFeatures: [
      '2 Professional Movers.',
      'Clean, fully stocked moving trucks.',
      'Delicate handling of your stuff.',
      'All taxes included in the price.',
    ],
  },
  {
    name: '3 Movers',
    href: '/book',
    priceMonthly: prices?.[0]?.three_men[0] ?? 0,
    priceKey: 'three_men',
    description: 'Starting from',
    sizes: '1-2 Bedroom Apt/House',
    includedFeatures: [
      '3 Professional Movers.',
      'Clean, fully stocked moving trucks.',
      'Delicate handling of your stuff.',
      'All taxes included in the price.',
    ],
    isPopular: true,
  },
  {
    name: '4 Movers',
    href: '/book',
    priceMonthly: prices?.[0]?.four_men[0] ?? 0,
    priceKey: 'four_men',
    description: 'Starting from',
    sizes: '3-4 Bedroom Apt/House',
    includedFeatures: [
      '4 Professional Movers.',
      'Clean, fully stocked moving trucks.',
      'Delicate handling of your stuff.',
      'All taxes included in the price.',
    ],
  },
];

const pricing = tv({
  base: '',
});

const { class: className = '' } = Astro.props;
---

<Section class={pricing({ class: className })}>
  <Container>
    <SectionHeader
      label="Pricing"
      title="Best prices, for everyone."
      subtitle="Affordable rates on professional moving services tailored to your needs."
    />
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        tiers.map((tier) => {
          const isPopular = tier.isPopular;

          if (isPopular) {
            return (
              <RotatingGradientBorder class="text-card-foreground group/card ring-border flex flex-col rounded-3xl bg-card py-6 relative overflow-visible gap-6 hover:shadow-lg hover:-translate-y-1 transition-all">
                {tier.isPopular && (
                  <div class="bg-secondary rounded-full text-secondary-foreground absolute top-[-12px] right-0 left-0 mx-auto w-fit px-4 py-1 text-center text-xs font-medium shadow-sm">
                    MOST POPULAR
                  </div>
                )}
                <CardHeader class="gap-0">
                  <CardTitle class="text-lg font-bold">{tier.name}</CardTitle>
                  <CardDescription>& Truck</CardDescription>
                </CardHeader>
                <CardContent>
                  <p class="text-muted-foreground mt-4 text-sm">
                    {tier.description}
                  </p>
                  <p class="text-4xl font-semibold tracking-tight">
                    $<span data-price={tier.priceKey}>{tier.priceMonthly}</span>
                    <span class="text-muted-foreground ml-1 text-sm font-normal tracking-normal">
                      per hour
                    </span>
                  </p>
                  <p class="my-8 font-semibold">{tier.sizes}</p>
                  <Button
                    variant="primary"
                    class="w-full"
                    title="Get a Quote"
                    href={tier.href}
                    aria-label="Get a Quote"
                  >
                    Get a Quote
                  </Button>
                  <div class="mt-6">
                    <p class="font-semibold">What&apos;s included</p>
                    <ul class="mt-6 space-y-4">
                      {tier.includedFeatures.map((feature) => (
                        <li class="flex space-x-3">
                          <CircleCheckIcon
                            class="size-5 shrink-0 mt-[3px] text-green-600"
                            aria-hidden="true"
                          />
                          <span>{feature}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                </CardContent>
              </RotatingGradientBorder>
            );
          }
          return (
            <Card class="hover:shadow-lg hover:-translate-y-1 transition-all">
              {tier.isPopular && (
                <div class="bg-secondary rounded-full text-secondary-foreground absolute top-[-12px] right-0 left-0 mx-auto w-fit px-4 py-1 text-center text-xs font-medium shadow-sm">
                  MOST POPULAR
                </div>
              )}
              <CardHeader class="gap-0">
                <CardTitle class="text-lg font-bold">{tier.name}</CardTitle>
                <CardDescription>& Truck</CardDescription>
              </CardHeader>
              <CardContent>
                <p class="text-muted-foreground mt-4 text-sm">
                  {tier.description}
                </p>
                <p class="text-4xl font-semibold tracking-tight">
                  $<span data-price={tier.priceKey}>{tier.priceMonthly}</span>
                  <span class="text-muted-foreground ml-1 text-sm font-normal tracking-normal">
                    per hour
                  </span>
                </p>
                <p class="my-8 font-semibold">{tier.sizes}</p>
                <Button
                  variant="primary"
                  class="w-full"
                  title="Get a Quote"
                  href={tier.href}
                  aria-label="Get a Quote"
                >
                  Get a Quote
                </Button>
                <div class="mt-6">
                  <p class="font-semibold">What&apos;s included</p>
                  <ul class="mt-6 space-y-4">
                    {tier.includedFeatures.map((feature) => (
                      <li class="flex space-x-3">
                        <CircleCheckIcon
                          class="size-5 shrink-0 mt-[3px] text-green-600"
                          aria-hidden="true"
                        />
                        <span>{feature}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </CardContent>
            </Card>
          );
        })
      }
      <div class="flex flex-col justify-between gap-6">
        <Card
          class="grow gap-2 hover:shadow-lg hover:-translate-y-1 transition-all"
        >
          <CardHeader>
            <CardTitle class="text-lg font-bold">Additional mover</CardTitle>
          </CardHeader>
          <CardContent>
            <p class="mt-4">
              <span class="text-4xl font-semibold tracking-tight">
                $<span data-price="add_men">{prices?.[0]?.add_men[0] ?? 0}</span
                >
              </span>
              <span class="text-muted-foreground text-sm">per hour</span>
            </p>
            <p class="mt-6 flex space-x-3">
              <CircleCheckIcon
                class="size-5 shrink-0 mt-[3px] text-green-600"
                aria-hidden="true"
              />
              <span>
                Rate per hour per mover added to your quoted houry rate if you
                request it.
              </span>
            </p>
          </CardContent>
        </Card>
        <Card
          class="grow gap-2 hover:shadow-lg hover:-translate-y-1 transition-all"
        >
          <CardHeader>
            <CardTitle class="text-lg font-bold">Additional truck</CardTitle>
          </CardHeader>
          <CardContent>
            <p class="mt-4">
              <span class="text-4xl font-semibold tracking-tight">
                $<span data-price="add_truck"
                  >{prices?.[0]?.add_truck[0] ?? 0}</span
                >
              </span>
              <span class="text-muted-foreground text-sm">per hour</span>
            </p>
            <p class="mt-6 flex space-x-3">
              <CircleCheckIcon
                class="size-5 shrink-0 mt-[3px] text-green-600"
                aria-hidden="true"
              />
              <span>
                Rate per hour per truck added to your quoted houry rate if you
                request it.
              </span>
            </p>
          </CardContent>
        </Card>
      </div>
    </div>
    <div class="col-span-12 flex flex-col p-8 text-center">
      <h3 class="mb-2 text-2xl font-bold" aria-label="Need a Custom Solution?">
        Need a Custom Solution?
      </h3>
      <p class="mb-4 text-lg">
        Contact us for a personalized quote tailored to your specific moving
        needs.
      </p>
      <Button
        variant="secondary"
        class="self-center"
        title="Contact Sales"
        href={`tel:${SITE.contactPhone}`}
        aria-label="Contact Sales"
      >
        <PhoneIcon slot="icon" aria-hidden="true" />
        Contact Sales
      </Button>
    </div>
  </Container>
</Section>

<script define:vars={{ PRICES_API_URL }} is:inline>
  (async () => {
    try {
      const prices = await fetch(PRICES_API_URL).then((r) => r.json());
      const first = prices?.[0];
      if (!first) return;

      const map = {
        two_men: first.two_men?.[0],
        three_men: first.three_men?.[0],
        four_men: first.four_men?.[0],
        add_men: first.add_men?.[0],
        add_truck: first.add_truck?.[0],
      };

      document.querySelectorAll('[data-price]').forEach((el) => {
        const val = map[el.dataset.price];
        if (val !== undefined) el.textContent = val;
      });
    } catch {
      // API unavailable — build-time prices remain visible
    }
  })();
</script>
