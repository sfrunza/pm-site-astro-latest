---
import Container from '@/components/Container.astro';
import Section from '@/components/Section.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import { Card } from '@/components/starwind/card';
import {
  Carousel,
  CarouselContent,
  CarouselItem,
  CarouselNext,
  CarouselPrevious,
} from '@/components/starwind/carousel';
import {
  MOVE_SUPPLY_PROFILES,
  getSupplyTotal,
} from '@/config/moving-supplies';
---

<Section id="packages" class="py-16">
  <Container>
    <SectionHeader title="Packages." />
    <Carousel opts={{ align: 'start' }}>
      <CarouselContent class="py-4 px-2">
        {
          MOVE_SUPPLY_PROFILES.map((houseSize) => (
            <CarouselItem class="pl-4 basis-[75%] sm:basis-[40%] lg:basis-[28.5%] xl:basis-[22.22%]">
              <Card class="p-0 overflow-hidden hover:-translate-y-1 transition-transform hover:shadow-lg">
                <table class="divide-y">
                  <thead>
                    <tr class="bg-muted">
                      <th scope="col" class="pl-6 py-2 text-left font-bold">
                        {houseSize.propertyType === 'house'
                          ? `${houseSize.label} house`
                          : `${houseSize.label} apt.`}
                      </th>
                      <th
                        scope="col"
                        class="pr-4 py-2 text-right font-semibold"
                      >
                        Qty
                      </th>
                    </tr>
                  </thead>
                  <tbody>
                    {Object.entries(houseSize.items).map((material) => (
                      <tr class="border-b">
                        <td class="text-left pl-4 py-2 font-medium">
                          {material[0]}
                        </td>
                        <td class="text-right text-muted-foreground pr-4 py-2">
                          {material[1]}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                  <tfoot>
                    <tr>
                      <th
                        scope="row"
                        class="pl-4 py-4 text-left sm:text-right font-normal text-muted-foreground table-cell md:pl-0"
                      >
                        Total price
                      </th>
                      <td class="pr-4 py-4 text-right text-muted-foreground">
                        ${getSupplyTotal(houseSize.items).toFixed(2)}
                      </td>
                    </tr>
                  </tfoot>
                </table>
              </Card>
            </CarouselItem>
          ))
        }
      </CarouselContent>
      <CarouselPrevious />
      <CarouselNext />
    </Carousel>
  </Container>
</Section>
