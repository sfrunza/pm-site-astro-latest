---
import Container from '@/components/Container.astro';
import Section from '@/components/Section.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import { Card } from '@/components/starwind/card';
import { MOVE_SUPPLY_PROFILES, getSupplyTotal } from '@/config/moving-supplies';
---

<Section id="packages" class="overflow-visible py-16">
  <Container>
    <SectionHeader title="Packages." position="left" class="mb-6" />
  </Container>
  <div class="carousel-breakout">
    <ul class="carousel-scroller" tabindex="0" aria-label="Packages">
      {
        MOVE_SUPPLY_PROFILES.map((houseSize) => (
          <li class="carousel-item w-64">
            <Card class="transition-transform overflow-hidden p-0 hover:-translate-y-1 hover:shadow-lg">
              <table class="divide-y">
                <thead>
                  <tr class="bg-muted">
                    <th scope="col" class="pl-6 py-2 text-left font-bold">
                      {houseSize.propertyType === 'house'
                        ? `${houseSize.label} house`
                        : `${houseSize.label} apt.`}
                    </th>
                    <th scope="col" class="pr-4 py-2 text-right font-semibold">
                      Qty
                    </th>
                  </tr>
                </thead>
                <tbody class="border-0">
                  {Object.entries(houseSize.items).map((material) => (
                    <tr class="not-last:border-b">
                      <td class="text-left pl-4 py-2 font-medium">
                        {material[0]}
                      </td>
                      <td class="text-right text-muted-foreground pr-4 py-2">
                        {material[1]}
                      </td>
                    </tr>
                  ))}
                </tbody>
                <tfoot class="hidden">
                  <tr>
                    <th
                      scope="row"
                      class="pl-4 py-4 text-left sm:text-right font-normal text-muted-foreground table-cell md:pl-0"
                    >
                      Total price
                    </th>
                    <td class="pr-4 py-4 text-right text-muted-foreground">
                      ${getSupplyTotal(houseSize.items).toFixed(2)}
                    </td>
                  </tr>
                </tfoot>
              </table>
            </Card>
          </li>
        ))
      }
    </ul>
  </div>
</Section>
