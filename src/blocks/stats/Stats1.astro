---
import Section from '@/components/Section.astro';
import Container from '@/components/Container.astro';
import Image from '@/components/starwind/image/Image.astro';
import moversTruck from '@/assets/2-movers-and-truck-opt.jpg';
import { MapPinIcon } from '@/icons';
import { tv } from 'tailwind-variants';
import type { HTMLAttributes } from 'astro/types';
import { SITE } from '@/config/site';

interface PlainStat {
  value: string;
  label: string;
}

interface Props extends HTMLAttributes<'section'> {
  class?: string;
  titleStart?: string;
  titleHighlight?: string;
  subtitle?: string;
  rating?: string;
  reviewCount?: string;
  routeValue?: string;
  routeLabel?: string;
  stats?: PlainStat[];
}

const stats1 = tv({ base: '' });

const {
  class: className = '',
  titleStart = SITE.businessShortName,
  titleHighlight = 'by the Numbers',
  subtitle = 'A decade of smooth, stress-free moves across Massachusetts',
  rating = '5.0',
  reviewCount = '240+ verified reviews',
  routeValue = '50+ Cities',
  routeLabel = 'served across Greater Boston & MetroWest',
  stats = [
    { value: '1,200+', label: 'Moves Completed' },
    { value: '10+ Years', label: 'Licensed & Insured Experience' },
  ],
  ...rest
} = Astro.props;
---

<Section class={stats1({ class: className })} {...rest}>
  <Container>
    <div
      class="relative overflow-hidden rounded-3xl bg-card border border-border"
    >
      <div class="relative overflow-hidden">
        <!-- Decorative bottom wave band -->
        <svg
          class="pointer-events-none absolute inset-x-0 bottom-0 h-20 w-full text-primary/10 sm:h-28"
          viewBox="0 0 1200 120"
          preserveAspectRatio="none"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M0 62 C 180 24 380 102 600 64 C 820 26 1010 94 1200 52 L1200 120 L0 120 Z"
          ></path>
        </svg>

        <div
          class="relative grid gap-10 px-6 pt-10 pb-14 sm:px-10 sm:pt-14 lg:grid-cols-[5fr_7fr] lg:gap-8 lg:pb-10"
        >
          <!-- Crew photo -->
          <div
            class="relative order-last mx-auto flex w-full max-w-xs items-end justify-center lg:order-first lg:max-w-sm"
          >
            <!-- Soft glow behind the photo -->
            <div
              class="absolute -inset-8 rounded-full bg-radial from-primary/25 via-primary/10 to-transparent blur-2xl"
              aria-hidden="true"
            >
            </div>

            <!-- Sun peeking behind the photo -->
            <svg
              class="absolute -top-7 -left-7 size-20 text-secondary"
              viewBox="0 0 80 80"
              fill="currentColor"
              aria-hidden="true"
            >
              <circle cx="40" cy="40" r="32" opacity="0.95"></circle>
            </svg>

            <!-- Birds -->
            <svg
              class="absolute -top-8 right-2 h-8 w-16 text-primary"
              viewBox="0 0 64 32"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              aria-hidden="true"
            >
              <path d="M6 22 q6 -9 13 0 q6 -9 13 0"></path>
              <path d="M38 8 q5 -8 11 0 q5 -8 11 0"></path>
            </svg>

            <!-- Organic blob shape behind the photo -->
            <figure
              class="relative aspect-4/5 w-full rotate-3 overflow-hidden rounded-[58%_42%_55%_45%/50%_58%_42%_50%]"
            >
              <div class="absolute inset-0 bg-primary/8" aria-hidden="true">
              </div>
              <Image
                src={moversTruck}
                alt={`Two ${SITE.businessShortName} crew members standing in front of a branded purple moving truck`}
                title={`Two ${SITE.businessShortName} crew members standing in front of a branded purple moving truck`}
                class="relative z-10 h-full w-full object-cover"
                widths={[320, 480, 640, 768]}
                sizes="(min-width: 1024px) 24rem, 20rem"
                loading="lazy"
                decoding="async"
                fetchpriority="low"
                quality={50}
              />
            </figure>
          </div>

          <!-- Content -->
          <div class="lg:pr-4">
            <div class="relative inline-block">
              <svg
                class="absolute -top-4 -left-5 size-5 text-secondary-accent"
                viewBox="0 0 20 20"
                fill="none"
                stroke="currentColor"
                stroke-width="3"
                stroke-linecap="round"
                aria-hidden="true"
              >
                <path d="M5 16 L8 6"></path>
                <path d="M12 17 L16 9"></path>
              </svg>
              <h2
                class="text-3xl font-extrabold tracking-tight text-pretty sm:text-4xl"
                aria-label={`${titleStart} by the Numbers`}
              >
                {titleStart}
                <span class="relative inline-block whitespace-nowrap">
                  {titleHighlight}
                  <svg
                    class="absolute -bottom-2 left-0 h-3 w-full text-secondary"
                    viewBox="0 0 220 12"
                    preserveAspectRatio="none"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="5"
                    stroke-linecap="round"
                    aria-hidden="true"
                  >
                    <path d="M4 8 Q 110 0 216 6"></path>
                    <path d="M30 10 Q 120 5 190 9" opacity="0.55"></path>
                  </svg>
                </span>
              </h2>
            </div>
            <p class="mt-4 text-lg text-muted-foreground">{subtitle}</p>

            <dl class="mt-10 grid items-center gap-x-6 gap-y-8 sm:grid-cols-2">
              <!-- Google Reviews -->
              <div
                class="w-fit -rotate-1 rounded-2xl bg-card px-6 py-5 shadow-xl ring-1 ring-border/60 transition-transform duration-300 hover:-translate-y-1"
              >
                <dt class="flex items-center gap-2">
                  <svg class="size-5" viewBox="0 0 24 24" aria-hidden="true">
                    <path
                      fill="#4285F4"
                      d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                    ></path>
                    <path
                      fill="#34A853"
                      d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                    ></path>
                    <path
                      fill="#FBBC05"
                      d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                    ></path>
                    <path
                      fill="#EA4335"
                      d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                    ></path>
                  </svg>
                  <span class="text-sm font-semibold">Google Reviews</span>
                </dt>
                <dd class="mt-1">
                  <span class="block text-4xl font-black tracking-tight">
                    {rating}
                  </span>
                  <span
                    class="mt-1.5 flex items-center gap-0.5 text-secondary"
                    role="img"
                    aria-label={`Rated ${rating} out of 5 stars`}
                  >
                    {
                      Array.from({ length: 5 }).map(() => (
                        <svg
                          class="size-4"
                          viewBox="0 0 24 24"
                          fill="currentColor"
                          aria-hidden="true"
                        >
                          <path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
                        </svg>
                      ))
                    }
                  </span>
                  <span class="mt-1.5 block text-xs text-muted-foreground">
                    {reviewCount}
                  </span>
                </dd>
              </div>

              <!-- Plain stat 1 -->
              <div>
                <dt class="sr-only">{stats[0].label}</dt>
                <dd>
                  <span class="block text-5xl font-black tracking-tight">
                    {stats[0].value}
                  </span>
                  <span
                    class="mt-1 block text-sm font-medium text-muted-foreground"
                  >
                    {stats[0].label}
                  </span>
                </dd>
              </div>

              <!-- Route / service-area -->
              <div
                class="stat-card flex w-fit rotate-1 items-center gap-4 rounded-2xl bg-card px-6 py-5 shadow-xl ring-1 ring-border/60 transition-transform duration-300 hover:-translate-y-1"
              >
                <dt class="sr-only">Cities served</dt>
                <dd class="flex items-center gap-4">
                  <span
                    class="relative block h-12 w-20 shrink-0"
                    aria-hidden="true"
                  >
                    <svg
                      class="absolute inset-0 h-full w-full text-secondary-accent"
                      viewBox="0 0 80 48"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-dasharray="1 7"
                    >
                      <path d="M16 38 C 30 46, 48 38, 60 20"></path>
                    </svg>
                    <MapPinIcon
                      class="absolute top-4 left-1 size-6 text-primary"
                    />
                    <MapPinIcon
                      class="absolute -top-1 right-1 size-7 text-error"
                    />
                  </span>
                  <span class="block">
                    <span class="block text-2xl font-extrabold tracking-tight">
                      {routeValue}
                    </span>
                    <span
                      class="mt-0.5 block max-w-40 text-xs text-muted-foreground"
                    >
                      {routeLabel}
                    </span>
                  </span>
                </dd>
              </div>

              <!-- Plain stat 2 -->
              <div>
                <dt class="sr-only">{stats[1].label}</dt>
                <dd>
                  <span class="block text-5xl font-black tracking-tight">
                    {stats[1].value}
                  </span>
                  <span
                    class="mt-1 block text-sm font-medium text-muted-foreground"
                  >
                    {stats[1].label}
                  </span>
                </dd>
              </div>
            </dl>
          </div>
        </div>
      </div>
    </div>
  </Container>
</Section>
