---
import Section from '@/components/Section.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import { Image } from '@/components/starwind/image';
import Container from '@/components/Container.astro';
import Prose from '@/components/starwind/prose';
import { tv } from 'tailwind-variants';

interface Props {
  title: string;
  subtitle?: string;
  label?: string;
  position?: 'left' | 'right' | 'center';
  image: ImageMetadata;
  alt: string;
  class?: string;
}

const featureImageLeft = tv({
  base: '',
});

const {
  title,
  subtitle,
  image,
  alt,
  position = 'center',
  label,
  class: className = '',
} = Astro.props;
---

<Section class={featureImageLeft({ class: className })}>
  <Container>
    <SectionHeader
      title={title}
      subtitle={subtitle}
      position={position}
      label={label}
    />
    <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
      <!-- Left Content -->
      <div class="order-first flex w-full justify-center">
        <div
          class="flex w-fit items-center max-h-[min(28rem,70dvh)] justify-center overflow-hidden rounded-3xl"
        >
          <Image
            src={image}
            alt={alt}
            title={alt}
            class="object-cover size-full"
            data-slot="image"
            decoding="async"
            loading="lazy"
            fetchpriority="low"
            height={450}
            width={700}
            quality={50}
          />
        </div>
      </div>

      <!-- Right Content -->
      <div class="flex min-w-0 w-full flex-col">
        <Prose class="max-w-none">
          <slot />
        </Prose>
      </div>
    </div>
  </Container>
</Section>
