---
import Section from '@/components/Section.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import Container from '@/components/Container.astro';
import type { RelatedLink } from '@/config/service-faqs';
import { ChevronRightIcon } from '@/icons';
import { tv } from 'tailwind-variants';
import { card } from '@/components/starwind/card/Card.astro';

interface Props {
  links: RelatedLink[];
  title?: string;
  class?: string;
}

const relatedServices = tv({
  base: '',
});

const {
  links,
  title = 'Related moving services',
  class: className = '',
} = Astro.props;

if (links.length === 0) return;
---

<Section class={relatedServices({ class: className })}>
  <Container>
    <SectionHeader position="left" title={title} label="Explore" />
    <ul class="mt-8 grid auto-rows-fr gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        links.map((link) => (
          <li>
            <a
              aria-label={link.label}
              href={link.href}
              class={card({
                class:
                  'group bg-muted/50 hover:shadow-lg gap-2 hover:-translate-y-1 transition-all min-h-16 hover:bg-muted h-full px-6',
              })}
            >
              <div class="flex items-start justify-between gap-3">
                <span class="text-lg font-semibold">{link.label}</span>
                <ChevronRightIcon aria-hidden="true" class="size-4 shrink-0" />
              </div>
              <p class="text-muted-foreground mt-2 flex-1 text-sm leading-relaxed">
                {link.description}
              </p>
            </a>
          </li>
        ))
      }
    </ul>
  </Container>
</Section>
