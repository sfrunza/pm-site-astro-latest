---
import Section from '@/components/Section.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import Container from '@/components/Container.astro';
import type { RelatedLink } from '@/config/service-faqs';
import { tv } from 'tailwind-variants';

interface Props {
  links: RelatedLink[];
  title?: string;
  class?: string;
}

const relatedServices = tv({
  base: '',
});

const {
  links,
  title = 'Related Moving Services',
  class: className = '',
} = Astro.props;

if (links.length === 0) return;
---

<Section class={relatedServices({ class: className })}>
  <Container>
    <SectionHeader position="left" title={title} label="Explore" />
    <ul
      role="list"
      class="mt-8 grid auto-rows-fr gap-6 sm:grid-cols-2 lg:grid-cols-3"
    >
      {
        links.map((link) => (
          <li role="listitem">
            <a
              href={link.href}
              aria-label={`${link.label} — local moving guide`}
              title={`${link.label} — local moving guide`}
              class="group flex h-full flex-col gap-1 rounded-3xl border border-primary/25 bg-primary/5 p-6 transition-all duration-150 hover:border-primary/40 hover:bg-primary/10 hover:shadow-sm"
            >
              <span class="font-semibold text-foreground transition-transform duration-150 group-hover:translate-x-0.5">
                {link.label}
              </span>
              <span class="text-sm text-muted-foreground">
                {link.description}
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </Container>
</Section>
