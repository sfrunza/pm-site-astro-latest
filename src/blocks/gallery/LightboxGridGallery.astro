---
import { getImage } from 'astro:assets';
import Container from '@/components/Container.astro';
import Section from '@/components/Section.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import { Image } from '@/components/starwind/image';
import { SITE } from '@/config/site';
import img1 from '@/assets/yelp-1.jpg';
import img2 from '@/assets/yelp-2.jpg';
import img3 from '@/assets/yelp-3.jpg';
import img4 from '@/assets/yelp-4.jpg';
import img6 from '@/assets/yelp-6.jpg';
import img7 from '@/assets/yelp-7.jpg';
import img9 from '@/assets/yelp-9.jpg';
import img11 from '@/assets/yelp-11.jpg';
import img12 from '@/assets/yelp-12.jpg';
import img14 from '@/assets/yelp-14.jpg';
import img15 from '@/assets/yelp-15.jpg';
import img16 from '@/assets/yelp-16.jpg';
import img17 from '@/assets/yelp-17.jpg';
import img18 from '@/assets/yelp-18.jpg';
import img19 from '@/assets/yelp-19.jpg';
import Button from '@/components/starwind/button';
import { ChevronLeftIcon, ChevronRightIcon, XIcon } from '@/icons';
import { tv } from 'tailwind-variants';

type GalleryImage = typeof img1;

const images: GalleryImage[] = [
  img1,
  img3,
  img4,
  img6,
  img12,
  img7,
  img9,
  img11,
  img14,
  img15,
  img16,
  img17,
  img2,
  img18,
  img19,
];

// Pre-generate optimized full-size versions for the lightbox so we serve
// appropriately sized images instead of the raw originals.
const slides = await Promise.all(
  images.map(async (src, index) => {
    const full = await getImage({
      src,
      width: 1024,
      quality: 50,
      format: 'webp',
    });
    return {
      thumb: src,
      full: full.src,
      alt: `${SITE.businessShortName} in action ${index + 1}`,
      width: src.width,
      height: src.height,
    };
  })
);

const galleryRoot = tv({
  base: '',
});
const { class: className } = Astro.props;

const rootClass = galleryRoot({ class: className });
---

<Section class={rootClass}>
  <Container>
    <SectionHeader label="Our Gallery" title="See Our Team At Work" />

    <ul class="gallery-masonry" data-lightbox-grid>
      {
        slides.map((slide, index) => (
          <li class="gallery-masonry-item">
            <button
              type="button"
              class="group block w-full cursor-pointer overflow-hidden rounded-3xl transition focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
              data-lightbox-trigger
              data-index={index}
              aria-label={`View ${slide.alt} in full size`}
            >
              <span class="gallery-masonry-frame relative block overflow-hidden bg-muted">
                <Image
                  src={slide.thumb}
                  alt={slide.alt}
                  title={slide.alt}
                  width={slide.width}
                  height={slide.height}
                  class="gallery-masonry-image block w-full"
                  decoding="async"
                  loading="lazy"
                  fetchpriority="low"
                  quality={50}
                />
                <span
                  class="pointer-events-none absolute inset-0 bg-black/0 transition-colors group-hover:bg-black/30 group-focus-visible:bg-black/30"
                  aria-hidden="true"
                />
              </span>
            </button>
          </li>
        ))
      }
    </ul>
  </Container>
</Section>

<dialog
  data-lightbox-dialog
  closedby="any"
  aria-label={`${SITE.businessShortName} Gallery viewer`}
  class="lightbox-dialog m-auto w-auto max-w-[calc(100vw-2rem)] border-0 bg-transparent p-0 backdrop:bg-black/80 backdrop:backdrop-blur-sm"
>
  <div class="relative flex flex-col items-center p-4 sm:p-6">
    <div class="relative">
      <img
        data-lightbox-image
        src=""
        alt=""
        class="block max-h-[75vh] w-auto max-w-[min(calc(100vw-4rem),64rem)] rounded-3xl object-contain shadow-2xl"
      />

      <Button
        variant="outline"
        size="icon-lg"
        tabindex="-1"
        data-lightbox-close
        class="absolute top-3 right-3 border-white/25 bg-white/15 text-white hover:bg-white/10 hover:text-white backdrop-blur-xs"
      >
        <XIcon stroke-width={2.5} />
      </Button>
    </div>

    <p data-lightbox-caption class="mt-3 text-center text-sm text-white/90"></p>

    <Button
      variant="outline"
      size="icon-lg"
      tabindex="-1"
      data-lightbox-prev
      class="absolute top-1/2 left-2 border-white/25 bg-white/15 text-white hover:bg-white/10 hover:text-white backdrop-blur-xs"
    >
      <ChevronLeftIcon stroke-width={2.5} />
    </Button>

    <Button
      variant="outline"
      size="icon-lg"
      tabindex="-1"
      data-lightbox-next
      class="absolute top-1/2 right-2 border-white/25 bg-white/15 text-white hover:bg-white/10 hover:text-white backdrop-blur-xs"
    >
      <ChevronRightIcon stroke-width={2.5} />
    </Button>
  </div>
</dialog>

<script is:inline define:vars={{ slides }}>
  (() => {
    const dialog = document.querySelector('[data-lightbox-dialog]');
    const grid = document.querySelector('[data-lightbox-grid]');
    if (!dialog || !grid) return;

    const imageEl = dialog.querySelector('[data-lightbox-image]');
    const captionEl = dialog.querySelector('[data-lightbox-caption]');
    const prevBtn = dialog.querySelector('[data-lightbox-prev]');
    const nextBtn = dialog.querySelector('[data-lightbox-next]');
    const closeBtn = dialog.querySelector('[data-lightbox-close]');

    let current = 0;

    const render = () => {
      const slide = slides[current];
      if (!slide) return;
      imageEl.src = slide.full;
      imageEl.alt = slide.alt;
      captionEl.textContent = `${current + 1} / ${slides.length}`;
    };

    const open = (index) => {
      current = index;
      render();
      if (typeof dialog.showModal === 'function') dialog.showModal();
    };

    const go = (delta) => {
      current = (current + delta + slides.length) % slides.length;
      render();
    };

    grid.addEventListener('click', (event) => {
      const trigger = event.target.closest('[data-lightbox-trigger]');
      if (!trigger) return;
      open(Number(trigger.dataset.index));
    });

    prevBtn?.addEventListener('click', () => go(-1));
    nextBtn?.addEventListener('click', () => go(1));
    closeBtn?.addEventListener('click', () => dialog.close());

    dialog.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowRight') {
        event.preventDefault();
        go(1);
      } else if (event.key === 'ArrowLeft') {
        event.preventDefault();
        go(-1);
      }
    });

    // Fallback light-dismiss for browsers without `closedby` support (Safari).
    if (!('closedBy' in HTMLDialogElement.prototype)) {
      dialog.addEventListener('click', (event) => {
        if (event.target !== dialog) return;
        const rect = dialog.getBoundingClientRect();
        const inside =
          rect.top <= event.clientY &&
          event.clientY <= rect.top + rect.height &&
          rect.left <= event.clientX &&
          event.clientX <= rect.left + rect.width;
        if (!inside) dialog.close();
      });
    }
  })();
</script>

<style>
  .lightbox-dialog:open {
    overflow: hidden;
  }

  /* Mobile: clean uniform 2-column grid */
  .gallery-masonry {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .gallery-masonry-frame {
    aspect-ratio: 1;
  }

  .gallery-masonry-image {
    height: 100%;
    object-fit: cover;
  }

  /* Tablet+: column masonry using each photo's natural proportions */
  @media (min-width: 768px) {
    .gallery-masonry {
      display: block;
      columns: 3;
      column-gap: 1rem;
    }

    .gallery-masonry-item {
      break-inside: avoid;
      margin-bottom: 1rem;
    }

    .gallery-masonry-frame {
      aspect-ratio: auto;
    }

    .gallery-masonry-image {
      display: block;
      width: 100%;
      height: auto;
      object-fit: unset;
    }
  }

  @media (min-width: 1024px) {
    .gallery-masonry {
      columns: 4;
    }
  }
</style>
