---
import heroBg from '@/assets/heros/home.webp';
import Container from '@/components/Container.astro';
import Section from '@/components/Section.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import { Card } from '@/components/starwind/card';
import { Image } from '@/components/starwind/image';
import { SITE } from '@/config/site';
---

<Section>
  <Container>
    <SectionHeader
      label="Our Gallery"
      title="See Our Team At Work"
      position="left"
      class="mb-6"
    />
  </Container>
  <div class="carousel-breakout">
    <ul
      class="carousel-scroller"
      tabindex="0"
      aria-label=`${SITE.businessShortName} Gallery`
    >
      {
        Array.from({ length: 5 }).map((_, index) => (
          <li class="carousel-item w-72">
            <div class="p-1">
              <Card class="aspect-square overflow-hidden p-0 ring-0 shadow-md">
                <Image
                  src={heroBg}
                  alt={`${SITE.businessShortName} Gallery ${index}`}
                  title={`${SITE.businessShortName} Gallery ${index}`}
                  class="size-full object-cover"
                  loading="lazy"
                  fetchpriority="low"
                />
              </Card>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</Section>
