---
import Section from '@/components/Section.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import {
  Card,
  CardHeader,
  CardTitle,
  CardContent,
  CardAction,
} from '@/components/starwind/card';
import { Button } from '@/components/starwind/button';
import { ArrowRightIcon, ChevronLeftIcon } from '@/icons';
import { services as defaultServices, type Service } from '@/config/services';
import Container from '@/components/Container.astro';
import { tv } from 'tailwind-variants';
import MouseRepelParticles from '@/components/MouseRepelParticles.astro';
import { SITE } from '@/config/site';
import sasha from '@/assets/sasha.png';
import Image from 'astro/components/Image.astro';

type Props = {
  class?: string;
  label?: string;
  title?: string;
  subtitle?: string;
  services?: Service[];
};

const services1 = tv({
  base: 'bg-muted/50 relative isolate overflow-hidden',
});

const {
  class: className = '',
  label = 'Our Services',
  title = 'Our Moving Services',
  subtitle = `${SITE.businessShortName} Boston is a premier moving company providing high-quality service across Greater Boston and beyond. We specialize in local, long-distance, commercial, and residential moves for a stress-free experience from start to finish.`,
  services = defaultServices,
} = Astro.props;
---

<Section id="services" class={services1({ class: className })}>
  <MouseRepelParticles />
  <Container>
    <div class="relative">
      <Image
        src={sasha}
        alt="A mover standing next to packed moving boxes"
        title="A mover standing next to packed moving boxes"
        width={460}
        height={780}
        quality={80}
        loading="lazy"
        decoding="async"
        fetchpriority="low"
        class="pointer-events-none absolute bottom-[-12%] z-10 right-0 hidden h-[50%] w-auto select-none object-contain lg:block"
      />
      <SectionHeader label={label} title={title} subtitle={subtitle} />
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          services.map((service) => (
            <Card class="group hover:shadow-lg hover:-translate-y-1 transition-all">
              <CardHeader>
                <CardTitle>{service.name}</CardTitle>
                <CardAction>
                  <Button
                    data-state="active"
                    variant="ghost"
                    size="icon-sm"
                    title={`Learn More about ${service.name}`}
                    aria-label={`Learn More about ${service.name}`}
                    href={service.href}
                    class="rotate-180"
                  >
                    <ChevronLeftIcon />
                  </Button>
                </CardAction>
              </CardHeader>
              <CardContent class="grow flex flex-col space-y-4">
                <p class="grow">{service.description}</p>
                <div>
                  <Button
                    variant="primary"
                    title={`Learn More about ${service.name}`}
                    aria-label={`Learn More about ${service.name}`}
                    href={service.href}
                  >
                    <ArrowRightIcon slot="icon" aria-hidden="true" />
                    Learn More<span class="sr-only">about {service.name}</span>
                  </Button>
                </div>
              </CardContent>
            </Card>
          ))
        }
      </div>
    </div>
  </Container>
</Section>
