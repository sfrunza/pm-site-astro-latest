---
import Button from '@/components/starwind/button';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { SITE } from '@/config/site';
import type { BreadcrumbItem } from '@/seo/breadcrumbs';
import { getLcpPreload, type LcpPreloadLink } from '@/utils/lcp-preload';
import type { ImageMetadata } from 'astro';
import { Picture } from 'astro:assets';

interface Props {
  bgImage: ImageMetadata;
  title: string;
  subtitle?: string;
  breadcrumbs?: BreadcrumbItem[];
}

const {
  bgImage,
  title = `Welcome to ${SITE.businessShortName}`,
  subtitle = 'Your trusted partner for stress-free moves.',
  breadcrumbs,
} = Astro.props;

export async function getHero2LcpPreload(
  src: ImageMetadata
): Promise<LcpPreloadLink> {
  return getLcpPreload(src);
}
---

<section
  class="parallax bg-background text-foreground @container h-[60svh] md:h-[75svh] overflow-hidden relative w-full"
>
  <!-- Background -->
  <Picture
    src={bgImage}
    alt={title}
    title={title}
    formats={['avif', 'webp']}
    fetchpriority="high"
    quality={50}
    loading="eager"
    decoding="async"
    fallbackFormat="webp"
    layout="full-width"
    fit="cover"
    position="center"
    priority
    pictureAttributes={{
      class:
        'parallax-bg pointer-events-none absolute inset-0 size-full [&>img]:size-full [&>img]:object-cover',
    }}
  />

  <!-- Overlay -->
  <div
    class="from-neutral-950/80 to-neutral-950/20 absolute inset-0 bg-linear-to-t"
    aria-hidden="true"
  >
  </div>

  {
    breadcrumbs && breadcrumbs.length > 1 && (
      <div class="absolute inset-x-0 top-0 z-10 pt-20 sm:pt-24">
        <div class="mx-auto max-w-7xl px-6">
          <Breadcrumbs items={breadcrumbs} variant="light" />
        </div>
      </div>
    )
  }

  <!-- Content -->
  <div
    class="flex absolute max-w-7xl mx-auto flex-col @3xl:pb-20 @xl:pb-16 inset-0 justify-end pb-12 px-6"
  >
    <div
      class="flex @xl:flex-row @xl:items-end @xl:justify-between flex-col gap-8 items-start"
    >
      <div class="@3xl:max-w-3xl @xl:max-w-2xl max-w-xl">
        <h1
          class="tracking-tight font-medium @3xl:text-7xl @xl:text-5xl text-shadow-lg text-4xl text-balance text-neutral-50"
        >
          {title}
        </h1>
        {
          subtitle && (
            <p class="mt-4 @xl:text-lg max-w-lg text-neutral-100 text-pretty text-shadow-lg">
              {subtitle}
            </p>
          )
        }
      </div>
      <div class="flex flex-wrap items-center gap-4">
        <Button href="/book" variant="outline" size="lg">Get a Quote</Button>
      </div>
    </div>
  </div>
</section>
