---
import { ShieldCheckIcon, ClockShieldIcon } from '@/icons';
import { SITE } from '@/config/site';

interface Props {
  rating?: string;
  reviewCount?: string;
  quoteTime?: string;
  quoteLabel?: string;
  googleMapsUrl?: string;
}

const {
  rating = '5.0',
  reviewCount = '240+ verified reviews',
  quoteTime = '~15 min',
  quoteLabel = 'To complete your quote',
  googleMapsUrl = 'https://www.google.com/maps/place/Phoenix+Moving+%26+Storage/@42.291787,-71.3626797,17z/data=!3m1!4b1!4m5!3m4!1s0x89e387680ffe9aeb:0x4651b1e640f15b41!8m2!3d42.291787!4d-71.360491',
} = Astro.props;

const floatCard =
  'rounded-2xl bg-card px-5 py-4 shadow-xl ring-1 ring-border/60 transition-transform duration-300 motion-safe:hover:-translate-y-1';
---

<div class="relative mx-auto w-full max-w-5xl lg:min-h-144 lg:py-6">
  {/* Mobile trust strip */}
  <ul
    class="mb-6 flex flex-wrap items-center justify-center gap-2 lg:hidden p-1"
    aria-label="Why book with us"
  >
    <li>
      <a
        href={googleMapsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="bg-card inline-flex items-center gap-1.5 rounded-full px-3 py-1.5 text-sm font-medium shadow-sm ring-1 ring-border/60 font-[system-ui]"
      >
        <svg class="size-4 shrink-0" viewBox="0 0 24 24" aria-hidden="true">
          <path
            fill="#4285F4"
            d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
          ></path>
          <path
            fill="#34A853"
            d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
          ></path>
          <path
            fill="#FBBC05"
            d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
          ></path>
          <path
            fill="#EA4335"
            d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
          ></path>
        </svg>
        {rating}★ · {reviewCount.replace(' verified reviews', '')}
      </a>
    </li>
    <li>
      <span
        class="bg-card inline-flex items-center gap-1.5 rounded-full px-3 py-1.5 text-sm font-medium shadow-sm ring-1 ring-border/60"
      >
        <ClockShieldIcon
          class="text-primary size-4 shrink-0"
          aria-hidden="true"
        />
        {quoteTime} quote
      </span>
    </li>
    <li>
      <span
        class="bg-card inline-flex items-center gap-1.5 rounded-full px-3 py-1.5 text-sm font-medium shadow-sm ring-1 ring-border/60"
      >
        <ShieldCheckIcon
          class="text-primary size-4 shrink-0"
          aria-hidden="true"
        />
        Licensed & insured
      </span>
    </li>
  </ul>

  {/* Desktop decorations */}
  <div
    class="pointer-events-none absolute inset-0 hidden lg:block"
    aria-hidden="true"
  >
    <div
      class="absolute top-1/2 left-1/2 size-112 -translate-x-1/2 -translate-y-1/2 rounded-full bg-radial from-primary/12 via-primary/5 to-transparent blur-2xl"
    >
    </div>

    {/* Arrow: top-left → form */}
    <svg
      class="absolute top-24 left-[15%] h-28 w-40 text-secondary-accent"
      viewBox="0 0 160 112"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-dasharray="1 7"
    >
      <path d="M8 20 C 48 8, 88 28, 128 52"></path>
    </svg>

    {/* Arrow: bottom-left → form */}
    <svg
      class="absolute bottom-28 left-[15%] h-24 w-36 text-primary/70"
      viewBox="0 0 144 96"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-dasharray="1 7"
    >
      <path d="M12 72 C 52 48, 92 36, 124 24"></path>
    </svg>

    {/* Arrow: top-right → form */}
    <svg
      class="absolute top-32 right-[15%] h-28 w-40 text-secondary"
      viewBox="0 0 160 112"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-dasharray="1 7"
    >
      <path d="M152 24 C 112 36, 72 48, 32 64"></path>
    </svg>

    {/* Accent marks above form */}
    <svg
      class="absolute top-2 left-1/2 size-5 -translate-x-8 text-secondary-accent"
      viewBox="0 0 20 20"
      fill="none"
      stroke="currentColor"
      stroke-width="3"
      stroke-linecap="round"
    >
      <path d="M5 16 L8 6"></path>
      <path d="M12 17 L16 9"></path>
    </svg>
  </div>

  {/* Desktop floating cards */}
  <div class="hidden lg:block">
    <a
      href={googleMapsUrl}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={`View our ${rating} star Google Reviews profile (opens in new tab)`}
      class={`${floatCard} absolute top-8 left-0 z-20 w-44 -rotate-2`}
    >
      <span class="flex items-center gap-2">
        <svg class="size-5 shrink-0" viewBox="0 0 24 24" aria-hidden="true">
          <path
            fill="#4285F4"
            d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
          ></path>
          <path
            fill="#34A853"
            d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
          ></path>
          <path
            fill="#FBBC05"
            d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
          ></path>
          <path
            fill="#EA4335"
            d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
          ></path>
        </svg>
        <span class="text-sm font-semibold">Google Reviews</span>
      </span>
      <span class="mt-1 block text-3xl font-black tracking-tight">{rating}</span
      >
      <span
        class="mt-1 flex items-center gap-0.5 text-secondary"
        role="img"
        aria-hidden="true"
      >
        {
          Array.from({ length: 5 }).map(() => (
            <svg class="size-3.5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
            </svg>
          ))
        }
      </span>
      <span class="mt-1 block text-xs text-muted-foreground">{reviewCount}</span
      >
    </a>

    <div class={`${floatCard} absolute bottom-16 left-4 z-20 w-40 rotate-1`}>
      <span class="flex items-center gap-2 text-sm font-semibold">
        <ClockShieldIcon
          class="text-primary size-5 shrink-0"
          aria-hidden="true"
        />
        Free estimate
      </span>
      <span class="mt-1 block text-3xl font-black tracking-tight"
        >{quoteTime}</span
      >
      <span class="mt-0.5 block text-xs text-muted-foreground"
        >{quoteLabel}</span
      >
    </div>

    <div class={`${floatCard} absolute top-20 right-0 z-20 w-44 -rotate-1`}>
      <span class="flex items-center gap-2 text-sm font-semibold">
        <ShieldCheckIcon
          class="text-primary size-5 shrink-0"
          aria-hidden="true"
        />
        Licensed & insured
      </span>
      <span class="mt-2 block text-xs leading-relaxed text-muted-foreground">
        MDPU #{SITE.businessLicenses.MDPU}<br />
        US DOT #{SITE.businessLicenses.DOT}
      </span>
    </div>
  </div>

  {/* Form embed */}
  <div class="relative z-10 mx-auto w-full max-w-xl">
    <slot />
  </div>
</div>
