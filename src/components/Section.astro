---
import type { HTMLAttributes } from 'astro/types';
import { tv, type VariantProps } from 'tailwind-variants';

const sectionRoot = tv({
  variants: {
    spacing: {
      none: '',
      sm: 'py-6 md:py-8',
      default: 'py-12 md:py-16',
      lg: 'py-16 md:py-24',
    },
  },
  defaultVariants: {
    spacing: 'default',
  },
});

interface Props
  extends HTMLAttributes<'section'>, VariantProps<typeof sectionRoot> {}

const { class: className, spacing, ...rest } = Astro.props;
---

<section
  class={sectionRoot({
    spacing,
    class: className,
  })}
  {...rest}
>
  <slot />
</section>
