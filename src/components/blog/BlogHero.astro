---
import { Image } from '@/components/starwind/image';
import type { ImageMetadata } from 'astro';
import { getLcpPreload, type LcpPreloadLink } from '@/utils/lcp-preload';

interface Props {
  title: string;
  categoryLabel: string;
  image?: ImageMetadata;
}

const { title, categoryLabel, image } = Astro.props;

/** Max display width inside Container (max-w-7xl) with px-4 padding. */
export const BLOG_HERO_IMAGE_SIZES =
  '(min-width: 80rem) 1280px, calc(100vw - 2rem)';
const heroSizes = BLOG_HERO_IMAGE_SIZES;
const heroWidths = [480, 640, 768, 896, 1024, 1280];

/** Pair with `<Layout lcpPreload={await getBlogHeroLcpPreload(image)} />`. */
export async function getBlogHeroLcpPreload(
  src: ImageMetadata | undefined
): Promise<(LcpPreloadLink & { imagesizes: string }) | undefined> {
  if (!src) return undefined;

  const preload = await getLcpPreload(src, { width: 896 });
  return { ...preload, imagesizes: BLOG_HERO_IMAGE_SIZES };
}
---

<div
  class="relative aspect-video w-full overflow-hidden rounded-3xl md:aspect-21/9"
  role="img"
  aria-label={`${categoryLabel}: ${title}`}
>
  {
    image ? (
      <Image
        src={image}
        alt={title}
        width={1280}
        height={672}
        widths={heroWidths}
        sizes={heroSizes}
        class="h-full w-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
    ) : (
      <div
        class="from-primary/80 via-primary to-amber-600/90 flex h-full w-full items-end bg-linear-to-br p-6 md:p-10"
        aria-hidden="true"
      >
        <div class="max-w-2xl">
          <p class="text-primary-foreground/90 text-sm font-medium tracking-wide uppercase">
            {categoryLabel}
          </p>
          <p class="text-primary-foreground mt-2 text-2xl font-bold leading-tight md:text-3xl">
            {title}
          </p>
        </div>
      </div>
    )
  }
</div>
