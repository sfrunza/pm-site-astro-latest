---
import { BLOG_AUTHOR } from '@/config/blog';
---

<aside
  class="bg-muted border-primary/20 border-l-4 mt-12 rounded-3xl p-6"
  aria-labelledby="author-bio-heading"
>
  <h2 id="author-bio-heading" class="text-lg font-semibold">
    About {BLOG_AUTHOR.name}
  </h2>
  <p class="text-muted-foreground mt-3 leading-relaxed">
    {BLOG_AUTHOR.bio}
  </p>
  <p class="text-muted-foreground mt-2 text-sm">{BLOG_AUTHOR.credentials}</p>
</aside>
