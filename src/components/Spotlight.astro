---
import type { HTMLAttributes } from 'astro/types';
import { randomUUID } from 'node:crypto';
import { tv } from 'tailwind-variants';

interface Props extends HTMLAttributes<'svg'> {
  /** Fill color for the spotlight ellipse. */
  fill?: string;
  /** Fill opacity for the spotlight ellipse (0–1). */
  fillOpacity?: number;
}

const spotlight = tv({
  base: [
    'pointer-events-none absolute z-1 h-[169%] w-[138%] opacity-0 lg:w-[84%]',
    'animate-spotlight motion-reduce:animate-none motion-reduce:opacity-100',
    'motion-reduce:translate-x-[-50%] motion-reduce:translate-y-[-40%] motion-reduce:scale-100',
  ],
});

const {
  fill = 'white',
  fillOpacity = 0.21,
  class: className,
  ...rest
} = Astro.props;

const filterId = `spotlight-filter-${randomUUID()}`;
---

<svg
  class={spotlight({ class: className })}
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 3787 2842"
  fill="none"
  aria-hidden="true"
  {...rest}
>
  <g filter={`url(#${filterId})`}>
    <ellipse
      cx="1924.71"
      cy="273.501"
      rx="1924.71"
      ry="273.501"
      transform="matrix(-0.822377 -0.568943 -0.568943 0.822377 3631.88 2291.09)"
      fill={fill}
      fill-opacity={fillOpacity}></ellipse>
  </g>
  <defs>
    <filter
      id={filterId}
      x="0.860352"
      y="0.838989"
      width="3785.16"
      height="2840.26"
      filterUnits="userSpaceOnUse"
      color-interpolation-filters="sRGB"
    >
      <feFlood flood-opacity="0" result="BackgroundImageFix"></feFlood>
      <feBlend
        mode="normal"
        in="SourceGraphic"
        in2="BackgroundImageFix"
        result="shape"></feBlend>
      <feGaussianBlur
        stdDeviation="151"
        result="effect1_foregroundBlur_1065_8"></feGaussianBlur>
    </filter>
  </defs>
</svg>
