---
import type { HTMLAttributes } from 'astro/types';
import { tv } from 'tailwind-variants';

interface Props extends HTMLAttributes<'div'> {
  /**
   * Number of particles per 100,000 px² of surface area. Higher = denser.
   * The real count is derived from the rendered size and clamped by `maxCount`.
   * @default 6
   */
  density?: number;
  /**
   * Hard upper bound on the particle count, regardless of density/size.
   * @default 90
   */
  maxCount?: number;
  /**
   * Smallest particle radius in CSS pixels.
   * @default 1
   */
  minSize?: number;
  /**
   * Largest particle radius in CSS pixels.
   * @default 3
   */
  maxSize?: number;
  /**
   * Base vertical drift speed in CSS pixels per second (particles float up).
   * @default 14
   */
  speed?: number;
  /**
   * Horizontal sway amplitude in CSS pixels.
   * @default 18
   */
  sway?: number;
  /**
   * Maximum particle opacity (0–1). Each particle twinkles below this.
   * @default 0.7
   */
  opacity?: number;
  /**
   * Particle / glow color (any CSS color value).
   * @default warm sunlit white
   */
  color?: string;
}

const floating = tv({
  base: 'floating-particles pointer-events-none absolute inset-0 -z-10 size-full overflow-hidden',
});

const {
  density = 6,
  maxCount = 90,
  minSize = 1,
  maxSize = 3,
  speed = 14,
  sway = 18,
  opacity = 0.7,
  color = 'oklch(0.97 0.04 95)',
  class: className,
  style,
  ...rest
} = Astro.props;
---

<div
  class={floating({ class: className })}
  style={`--floating-particles-color: ${color}; ${style ?? ''}`}
  data-slot="floating-particles"
  data-density={density}
  data-max-count={maxCount}
  data-min-size={minSize}
  data-max-size={maxSize}
  data-speed={speed}
  data-sway={sway}
  data-opacity={opacity}
  aria-hidden="true"
  {...rest}
>
  <canvas class="block size-full"></canvas>
</div>

<script>
  interface Particle {
    x: number;
    y: number;
    size: number;
    /** Vertical drift speed in px/s (positive = upward). */
    speed: number;
    /** Per-particle sway amplitude in px. */
    sway: number;
    /** Horizontal sway frequency in rad/s. */
    swayFreq: number;
    /** Sway phase offset in rad. */
    swayPhase: number;
    /** Peak opacity for this particle. */
    alpha: number;
    /** Twinkle frequency in rad/s. */
    twinkleFreq: number;
    /** Twinkle phase offset in rad. */
    twinklePhase: number;
  }

  const initialized = new WeakSet<HTMLElement>();

  function readNumber(el: HTMLElement, key: string, fallback: number) {
    const value = Number(el.dataset[key]);
    return Number.isFinite(value) ? value : fallback;
  }

  function rand(min: number, max: number) {
    return min + Math.random() * (max - min);
  }

  function initFloatingParticles(root: HTMLElement) {
    if (initialized.has(root)) return;
    initialized.add(root);

    const canvas = root.querySelector('canvas');
    if (!canvas) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const density = readNumber(root, 'density', 6);
    const maxCount = readNumber(root, 'maxCount', 90);
    const minSize = readNumber(root, 'minSize', 1);
    const maxSize = readNumber(root, 'maxSize', 3);
    const baseSpeed = readNumber(root, 'speed', 14);
    const baseSway = readNumber(root, 'sway', 18);
    const maxAlpha = readNumber(root, 'opacity', 0.7);

    const reducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches;

    let particles: Particle[] = [];
    let width = 0;
    let height = 0;
    let dpr = 1;
    let frameId = 0;
    let running = false;
    let visible = true;
    let lastTime = 0;

    // Soft round glow sprite, pre-rendered once and tinted with the target
    // color. drawImage(sprite) per particle is far cheaper than building a
    // radial gradient every frame.
    let sprite: HTMLCanvasElement | null = null;
    const SPRITE_SIZE = 64;

    const abort = new AbortController();
    const { signal } = abort;

    const getColor = () =>
      getComputedStyle(root)
        .getPropertyValue('--floating-particles-color')
        .trim() || 'oklch(0.97 0.04 95)';

    const buildSprite = () => {
      const s = document.createElement('canvas');
      s.width = SPRITE_SIZE;
      s.height = SPRITE_SIZE;
      const sctx = s.getContext('2d');
      if (!sctx) return;

      const r = SPRITE_SIZE / 2;
      const gradient = sctx.createRadialGradient(r, r, 0, r, r, r);
      gradient.addColorStop(0, 'rgba(255,255,255,1)');
      gradient.addColorStop(0.35, 'rgba(255,255,255,0.85)');
      gradient.addColorStop(1, 'rgba(255,255,255,0)');
      sctx.fillStyle = gradient;
      sctx.beginPath();
      sctx.arc(r, r, r, 0, Math.PI * 2);
      sctx.fill();

      // Tint the white glow with the configured color while preserving its
      // soft alpha falloff.
      sctx.globalCompositeOperation = 'source-in';
      sctx.fillStyle = getColor();
      sctx.fillRect(0, 0, SPRITE_SIZE, SPRITE_SIZE);

      sprite = s;
    };

    const makeParticle = (atRandomY: boolean): Particle => ({
      x: rand(0, width),
      y: atRandomY ? rand(0, height) : height + rand(0, height * 0.2),
      size: rand(minSize, maxSize),
      speed: baseSpeed * rand(0.5, 1.3),
      sway: baseSway * rand(0.4, 1),
      swayFreq: rand(0.3, 0.9),
      swayPhase: rand(0, Math.PI * 2),
      alpha: maxAlpha * rand(0.4, 1),
      twinkleFreq: rand(0.4, 1.4),
      twinklePhase: rand(0, Math.PI * 2),
    });

    const buildParticles = () => {
      const area = width * height;
      const target = Math.min(
        maxCount,
        Math.max(8, Math.round((area / 100_000) * density))
      );
      particles = Array.from({ length: target }, () => makeParticle(true));
    };

    const drawParticle = (p: Particle, alpha: number) => {
      if (!sprite) return;
      const drawn = p.size * 4; // sprite is mostly soft glow; scale up the core
      ctx.globalAlpha = Math.max(0, Math.min(1, alpha));
      ctx.drawImage(sprite, p.x - drawn / 2, p.y - drawn / 2, drawn, drawn);
    };

    const drawStatic = () => {
      ctx.clearRect(0, 0, width, height);
      for (const p of particles) drawParticle(p, p.alpha);
      ctx.globalAlpha = 1;
    };

    const resize = () => {
      const rect = root.getBoundingClientRect();
      width = Math.max(1, Math.floor(rect.width));
      height = Math.max(1, Math.floor(rect.height));
      dpr = Math.min(window.devicePixelRatio || 1, 2);

      canvas.width = Math.floor(width * dpr);
      canvas.height = Math.floor(height * dpr);
      canvas.style.width = `${width}px`;
      canvas.style.height = `${height}px`;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

      buildParticles();
      if (reducedMotion) drawStatic();
    };

    const step = (time: number) => {
      const dt = Math.min(0.05, (time - lastTime) / 1000 || 0);
      lastTime = time;
      const t = time / 1000;

      ctx.clearRect(0, 0, width, height);

      for (const p of particles) {
        p.y -= p.speed * dt;
        const swayX = Math.sin(t * p.swayFreq + p.swayPhase) * p.sway * dt;
        p.x += swayX;

        // Recycle particles once they drift above the top.
        if (p.y + p.size * 2 < 0) {
          p.y = height + p.size * 2;
          p.x = rand(0, width);
        }
        if (p.x < -p.size * 4) p.x = width + p.size * 2;
        else if (p.x > width + p.size * 4) p.x = -p.size * 2;

        const twinkle =
          0.65 + 0.35 * Math.sin(t * p.twinkleFreq + p.twinklePhase);
        drawParticle(p, p.alpha * twinkle);
      }

      ctx.globalAlpha = 1;
    };

    const loop = (time: number) => {
      if (!running) return;
      step(time);
      frameId = window.requestAnimationFrame(loop);
    };

    const start = () => {
      if (reducedMotion || running || !visible) return;
      running = true;
      lastTime = performance.now();
      frameId = window.requestAnimationFrame(loop);
    };

    const stop = () => {
      running = false;
      window.cancelAnimationFrame(frameId);
    };

    const intersection = new IntersectionObserver(
      (entries) => {
        visible = entries.some((entry) => entry.isIntersecting);
        if (visible) start();
        else stop();
      },
      { root: null, threshold: 0 }
    );

    root.addEventListener(
      'contentvisibilityautostatechange',
      (event) => {
        const skipped = (event as ContentVisibilityAutoStateChangeEvent)
          .skipped;
        if (skipped) stop();
        else if (visible) start();
      },
      { signal }
    );

    window.addEventListener(
      'resize',
      () => {
        resize();
        if (reducedMotion) drawStatic();
      },
      { signal }
    );

    const resizeObserver = new ResizeObserver(() => {
      resize();
      if (reducedMotion) drawStatic();
    });
    resizeObserver.observe(root);

    buildSprite();
    intersection.observe(root);
    resize();

    if (reducedMotion) {
      drawStatic();
      return;
    }

    start();

    return () => {
      stop();
      abort.abort();
      resizeObserver.disconnect();
      intersection.disconnect();
    };
  }

  function initAll() {
    document
      .querySelectorAll<HTMLElement>('[data-slot="floating-particles"]')
      .forEach((root) => initFloatingParticles(root));
  }

  document.addEventListener('astro:page-load', initAll);
  if (document.readyState !== 'loading') initAll();
</script>

<style>
  @media (prefers-reduced-motion: no-preference) {
    .floating-particles {
      content-visibility: auto;
      contain-intrinsic-size: auto none auto 24rem;
    }
  }
</style>
