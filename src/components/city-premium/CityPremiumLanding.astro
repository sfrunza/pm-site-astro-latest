---
import CTA1 from '@/blocks/cta/CTA1.astro';
import Feature3 from '@/blocks/feature/Feature3.astro';
import FeatureImageRight from '@/blocks/feature/FeatureImageRight.astro';
import RenderCityPremiumSection from './RenderCityPremiumSection.astro';
import Button from '@/components/starwind/button';
import Hero2 from '@/components/Hero2.astro';
import {
  DEFAULT_CITY_PREMIUM_SECTION_ORDER,
  type CityPremiumContent,
} from '@/config/city-premium/types';
import { SITE } from '@/config/site';
import type { ImageMetadata } from 'astro';
import BlogPreview1 from '@/blocks/blog/BlogPreview1.astro';
import Cities1 from '@/blocks/cities/Cities1.astro';

interface Props {
  content: CityPremiumContent;
  cityHero: ImageMetadata;
  cityLogo: ImageMetadata;
}

const { content, cityHero, cityLogo } = Astro.props;
const c = content;
const office = SITE.businessAddresses[c.intro.officeIndex ?? 0];
const phoneTel = SITE.contactPhone;
const sectionOrder = c.sectionOrder ?? DEFAULT_CITY_PREMIUM_SECTION_ORDER;
---

<Hero2 bgImage={cityHero} title={c.hero.title} subtitle={c.hero.subtitle} />

<Feature3 features={c.trustFeatures} />

<FeatureImageRight
  label={c.intro.label}
  title={c.intro.title}
  subtitle={c.directAnswer}
  position="left"
  image={cityLogo}
  alt={c.intro.imageAlt}
  class="defer-section"
>
  <address class="not-italic space-y-2 text-sm">
    <p>
      <strong>{SITE.businessName}</strong><br />
      {office.address}<br />
      {office.city}, {office.state}
      {office.zip}
    </p>
    <p>
      Phone: <a
        href={`tel:${phoneTel}`}
        aria-label={`Call ${SITE.businessName}`}>{SITE.contactPhone}</a
      ><br />
      Email: <a
        href={`mailto:${SITE.contactEmail}`}
        aria-label={`Email ${SITE.businessName}`}>{SITE.contactEmail}</a
      >
    </p>
    <p>Hours: {SITE.businessHours}</p>
  </address>
  <p>
    Ready to move within {c.schema.cityName} or across Massachusetts? Compare our
    <a href="/pricing" aria-label="Compare moving prices">moving prices</a>,
    explore
    <a href="/local-moving" aria-label="Explore local moving services"
      >local moving services</a
    >, or
    <a href="/book" aria-label="Book your free quote">book your free quote</a> today.
  </p>

  <Fragment slot="actions">
    <Button variant="primary" href="/book" aria-label="Book your free quote"
      >Get a free quote</Button
    >
    <Button variant="secondary" href="/pricing" aria-label="View pricing"
      >View pricing</Button
    >
  </Fragment>
</FeatureImageRight>

{
  sectionOrder.map((sectionId) => (
    <RenderCityPremiumSection
      id={sectionId}
      content={c}
      cityHero={cityHero}
      phoneTel={phoneTel}
    />
  ))
}

<!-- Blog preview: 3 featured posts + "Browse all" CTA -->
<BlogPreview1 class="defer-section" />

<Cities1 currentSlug={c.path} class="defer-section" />

<!-- CTA -->
<CTA1
  title={c.finalCta.title}
  description={c.finalCta.description}
  class="defer-section"
/>
