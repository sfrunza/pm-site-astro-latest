---
import CTA2 from '@/blocks/cta/CTA2.astro';
import FAQDetails from '@/blocks/faq/FAQDetails.astro';
import Feature2 from '@/blocks/feature/Feature2.astro';
import FeatureImageLeft from '@/blocks/feature/FeatureImageLeft.astro';
import Process1 from '@/blocks/process/Process1.astro';
import RelatedServices from '@/blocks/related/RelatedServices.astro';
import Services1 from '@/blocks/services/Services1.astro';
import Container from '@/components/Container.astro';
import Section from '@/components/Section.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import Button from '@/components/starwind/button';
import { Image } from '@/components/starwind/image';
import Prose from '@/components/starwind/prose';
import {
  Card,
  CardContent,
  CardHeader,
  CardTitle,
} from '@/components/starwind/card';
import type {
  CityPremiumContent,
  CityPremiumSectionId,
} from '@/config/city-premium/types';
import { SITE } from '@/config/site';
import type { ImageMetadata } from 'astro';
import MouseRepelParticles from '../MouseRepelParticles.astro';
import Reviews1 from '@/blocks/reviews/Reviews1.astro';
import { ChevronRightIcon } from '@/icons';
import FeatureImageRight from '@/blocks/feature/FeatureImageRight.astro';
import MovingChecklist1 from '@/blocks/checklist/MovingChecklist1.astro';
import Stats1 from '@/blocks/stats/Stats1.astro';

interface Props {
  id: CityPremiumSectionId;
  content: CityPremiumContent;
  cityHero: ImageMetadata;
  phoneTel: string;
}

const { id, content: c, cityHero, phoneTel } = Astro.props;
---

{
  id === 'services' &&
    (c.services ? (
      <Services1
        label={c.services.label}
        title={c.services.title}
        subtitle={c.services.subtitle}
      />
    ) : (
      <Services1 />
    ))
}

{
  id === 'movingInCity' && c.movingInCity && (
    <FeatureImageLeft
      title={c.movingInCity.title}
      subtitle={c.movingInCity.subtitle}
      image={cityHero}
      alt={c.movingInCity.imageAlt}
    >
      {c.movingInCity.paragraphs.map((paragraph) => (
        <p set:html={paragraph} />
      ))}
    </FeatureImageLeft>
  )
}

{
  id === 'moveTypes' && c.moveTypes && (
    <Section class="defer-section">
      <Container class="@container">
        <SectionHeader
          label={c.moveTypes.label}
          title={c.moveTypes.title}
          subtitle={c.moveTypes.subtitle}
          position="center"
        />
        <div class="mt-12 grid gap-6 @md:grid-cols-2 @2xl:grid-cols-3">
          {c.moveTypes.items.map((moveType) => (
            <Card class="h-full">
              <CardHeader>
                <CardTitle>
                  <h3 aria-label={moveType.title}>{moveType.title}</h3>
                </CardTitle>
              </CardHeader>
              <CardContent>
                <p>{moveType.description}</p>
              </CardContent>
            </Card>
          ))}
        </div>
        <div class="mt-10 flex flex-wrap justify-center gap-3">
          <Button
            variant="primary"
            href="/book"
            aria-label={
              c.moveTypes.quoteButtonLabel ??
              `Get a ${c.schema.cityName} moving quote`
            }
          >
            {c.moveTypes.quoteButtonLabel ??
              `Get a ${c.schema.cityName} moving quote`}
          </Button>
          {c.moveTypes.showPianoLink && (
            <Button
              variant="outline"
              href="/piano-moving"
              aria-label="Piano & specialty moves"
            >
              Piano & specialty moves
            </Button>
          )}
        </div>
      </Container>
    </Section>
  )
}

{
  id === 'whyChoose' && (
    <Feature2
      title={c.whyChoose.title}
      subtitle={c.whyChoose.subtitle}
      label={c.whyChoose.label}
      position="center"
      features={c.whyChoose.features}
      class="defer-section"
    />
  )
}

{
  id === 'howTo' && (
    <Process1
      label={c.howTo.label}
      title={c.howTo.title}
      subtitle={c.howTo.subtitle}
      steps={c.howTo.steps}
      class="defer-section"
    />
  )
}

{
  id === 'neighborhoods' && (
    <Section class="defer-section">
      <Container class="@container">
        <SectionHeader
          label={c.neighborhoods.label}
          title={c.neighborhoods.title}
          subtitle={c.neighborhoods.subtitle}
          position="center"
        />
        <div class="mt-12 grid gap-6 @md:grid-cols-2 @2xl:grid-cols-4">
          {c.neighborhoods.areas.map((area) => (
            <Card class="h-full">
              <CardHeader>
                <CardTitle>
                  <h3 aria-label={area.title}>{area.title}</h3>
                </CardTitle>
              </CardHeader>
              <CardContent>
                <p>{area.description}</p>
              </CardContent>
            </Card>
          ))}
        </div>
        <div class="mt-12">
          <h3
            class="text-lg font-semibold"
            aria-label={
              c.neighborhoods.nearbyHeading ?? 'Nearby towns we also serve'
            }
          >
            {c.neighborhoods.nearbyHeading ?? 'Nearby towns we also serve'}
          </h3>
          <ul class="mt-4 flex flex-wrap gap-3">
            {c.nearbyTowns.map((town) => (
              <li>
                <a
                  href={town.href}
                  aria-label={town.label}
                  class="bg-muted/50 inline-flex hover:bg-muted hover:shadow-lg hover:-translate-y-1 transition-all rounded-full px-4 py-2 text-sm font-medium border border-border"
                >
                  <div class="flex items-center gap-2">
                    <span>{town.label}</span>
                    <ChevronRightIcon
                      aria-hidden="true"
                      class="size-4 shrink-0"
                    />
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </Container>
    </Section>
  )
}

{
  id === 'midCta' && c.midCta && (
    <CTA2
      title={c.midCta.title}
      description={c.midCta.description}
      primaryButton={{ text: 'Request a free estimate', href: '/book' }}
      secondaryButton={{ text: 'View moving prices', href: '/pricing' }}
      class="defer-section"
    />
  )
}

{
  id === 'pricing' && (
    <Section class="bg-muted/50 relative isolate overflow-hidden defer-section">
      <MouseRepelParticles />
      <Container class="@container">
        <SectionHeader
          label={c.pricing.label}
          title={c.pricing.title}
          subtitle={c.pricing.subtitle}
          position="center"
        />
        {c.pricing.factors && (
          <div class="mt-12 grid gap-6 @md:grid-cols-2">
            {c.pricing.factors.map((factor) => (
              <Card class="h-full">
                <CardHeader>
                  <CardTitle>
                    <h3 aria-label={factor.title}>{factor.title}</h3>
                  </CardTitle>
                </CardHeader>
                <CardContent>
                  <p>{factor.description}</p>
                </CardContent>
              </Card>
            ))}
          </div>
        )}
        <div class="mt-10 flex flex-wrap justify-center gap-3">
          <Button
            variant="primary"
            href="/pricing"
            aria-label="See moving prices"
          >
            See moving prices
          </Button>
          <Button
            variant="secondary"
            href="/book"
            aria-label="Get a free estimate"
          >
            Get a free estimate
          </Button>
        </div>
      </Container>
    </Section>
  )
}

{
  id === 'commercial' && c.commercial && (
    <FeatureImageRight
      label={c.commercial.label}
      title={c.commercial.title}
      subtitle={c.commercial.subtitle}
      position="left"
      image={cityHero}
      alt={c.commercial.imageAlt}
    >
      {c.commercial.paragraphs.map((paragraph) => (
        <p>{paragraph}</p>
      ))}
      <p>
        <a href="/book" aria-label="Request a commercial moving quote">
          Request a commercial moving quote
        </a>{' '}
        or call{' '}
        <a href={`tel:${phoneTel}`} aria-label={`Call ${SITE.contactPhone}`}>
          {SITE.contactPhone}
        </a>{' '}
        to discuss your {c.schema.cityName} office timeline.
      </p>
    </FeatureImageRight>
  )
}

{
  id === 'localGuide' && c.localGuide && (
    <Section class="defer-section">
      <Container class="@container">
        <SectionHeader
          label={c.localGuide.label}
          title={c.localGuide.title}
          subtitle={c.localGuide.subtitle}
          position="left"
        />
        <Prose class="mt-8 max-w-none">
          {c.localGuide.paragraphs.map((paragraph) => (
            <p set:html={paragraph} />
          ))}
        </Prose>
      </Container>
    </Section>
  )
}

{
  id === 'prepTips' && c.prepTips && (
    <Section class="defer-section">
      <Container class="@container">
        <SectionHeader
          label={c.prepTips.label}
          title={c.prepTips.title}
          subtitle={c.prepTips.subtitle}
          position="center"
        />
        <ul class="mx-auto mt-10 max-w-2xl space-y-4">
          {c.prepTips.tips.map((tip) => (
            <li class="bg-muted/50 flex gap-3 rounded-2xl px-6 py-4 text-pretty">
              <span
                class="text-primary shrink-0 font-semibold"
                aria-hidden="true"
              >
                ✓
              </span>
              <span>{tip}</span>
            </li>
          ))}
        </ul>
      </Container>
    </Section>
  )
}

{
  id === 'movingChecklist' && c.movingChecklist && (
    <MovingChecklist1 class="defer-section bg-linear-to-t from-muted/50 to-transparent" />
  )
}

{
  id === 'reviews' && c.reviews && (
    <>
      <Reviews1 class="defer-section" />
      <Stats1 class="bg-linear-to-b from-muted/50 to-transparent defer-section" />
    </>
  )
}

{
  id === 'faq' && (
    <FAQDetails
      class="defer-section"
      items={c.faq.items}
      title={c.faq.title}
      label={c.faq.label}
      groupName={c.faq.groupName}
    />
  )
}

{
  id === 'related' && (
    <RelatedServices
      links={c.relatedLinks}
      title={c.relatedTitle}
      class="defer-section"
    />
  )
}
