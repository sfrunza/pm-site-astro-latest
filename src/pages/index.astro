---
import Layout from '../layouts/Layout.astro';
import Hero, { getHomeHeroLcpPreload } from '@/components/Hero.astro';
import Pricing1 from '@/blocks/pricing/Pricing1.astro';
import Services1 from '@/blocks/services/Services1.astro';
import Feature1 from '@/blocks/feature/Feature1.astro';
import CTA1 from '@/blocks/cta/CTA1.astro';
import Cities1 from '@/blocks/cities/Cities1.astro';
import RelatedServices from '@/blocks/related/RelatedServices.astro';
import { getRelatedLinks } from '@/config/service-faqs';
import feature1Image from '@/assets/2-movers-and-truck-opt.jpg';
import { fetchHomeSeo } from '@/seo';
import ImageCompareSlider from '@/components/ImageCompareSlider.astro';
import Section from '@/components/Section.astro';
import Container from '@/components/Container.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import shkafBefore from '@/assets/shkaf-before.jpeg';
import shkafAfter from '@/assets/shkaf-after.jpeg';
import medicalChairBefore from '@/assets/medical-chair-before.jpeg';
import medicalChairAfter from '@/assets/medical-chair-after.jpeg';
import Reviews1 from '@/blocks/reviews/Reviews1.astro';
import Partners1 from '@/blocks/partners/Partners1.astro';
import Stats1 from '@/blocks/stats/Stats1.astro';
import Process1 from '@/blocks/process/Process1.astro';
import BlogPreview1 from '@/blocks/blog/BlogPreview1.astro';
import MovingChecklist1 from '@/blocks/checklist/MovingChecklist1.astro';

const [seo, lcpPreload] = await Promise.all([
  fetchHomeSeo(Astro.url),
  getHomeHeroLcpPreload(),
]);
---

<Layout {...seo} lcpPreload={lcpPreload}>
  <Hero />

  <!-- Trust logos -->
  <Partners1
    class="bg-linear-to-t from-muted/50 to-transparent defer-section"
  />

  <!-- Services -->
  <Services1 class="defer-section" />

  <!-- Pricing -->
  <Pricing1 class="defer-section" />

  <!-- How It Works — 4-step process with HowTo schema -->
  <Process1 class="defer-section" />

  <!-- Trust numbers: 1,200+ moves · 5.0 rating · 10 yrs · 100% insured -->
  <Stats1 class="bg-linear-to-t from-muted/50 to-transparent defer-section" />

  <!-- Furniture wrapping before/after -->
  <Section class="defer-section bg-muted/50">
    <Container>
      <SectionHeader
        label="Protection That Shows"
        title="Expert Furniture Wrapping"
        subtitle="Every piece of furniture is professionally wrapped and protected before transport. See the difference our meticulous packing makes."
      />
      <div
        class="flex flex-col sm:flex-row justify-center items-center gap-12 sm:gap-24 max-w-3xl mx-auto"
      >
        <ImageCompareSlider
          beforeSrc={shkafBefore}
          afterSrc={shkafAfter}
          beforeLabel="Before"
          afterLabel="After"
          alt="Shkaf before and after"
        />
        <ImageCompareSlider
          beforeSrc={medicalChairBefore}
          afterSrc={medicalChairAfter}
          beforeLabel="Before"
          afterLabel="After"
          alt="Medical chair before and after"
        />
      </div>
    </Container>
  </Section>

  <!-- Feature -->
  <Feature1
    image={{ src: feature1Image, alt: '2 Movers and Truck' }}
    class="defer-section"
  />

  <!-- 8-week moving timeline teaser + link to full checklist -->
  <MovingChecklist1
    class="defer-section bg-linear-to-t from-muted/50 to-transparent"
  />

  <!-- Reviews -->
  <Reviews1 class="defer-section" />

  <!-- Service areas -->
  <Cities1 class="defer-section" />

  <!-- Blog preview: 3 featured posts + "Browse all" CTA -->
  <BlogPreview1 class="defer-section" />

  <!-- Related services -->
  <RelatedServices links={getRelatedLinks('/')} class="defer-section" />

  <!-- CTA -->
  <CTA1 class="defer-section" />
</Layout>
