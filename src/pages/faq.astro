---
import Layout from '../layouts/Layout.astro';
import Hero2, { getHero2LcpPreload } from '@/components/Hero2.astro';
import FAQ1 from '@/blocks/faq/FAQ1.astro';
import { faqs } from '@/blocks/faq/faqs';
import CTA1 from '@/blocks/cta/CTA1.astro';
import heroBg from '@/assets/heros/faq.jpg';
import RelatedServices from '@/blocks/related/RelatedServices.astro';
import {
  buildFaqJsonLd,
  fetchPageSeo,
  getSocialImageUrl,
  stripHtmlForSchema,
} from '@/seo';
import { getRelatedLinks } from '@/config/service-faqs';
import { SITE } from '@/config/site';

const lcpPreload = await getHero2LcpPreload(heroBg);
const socialImageUrl = await getSocialImageUrl(heroBg);

const seo = await fetchPageSeo(Astro.url, {
  title: `Frequently Asked Questions | ${SITE.businessName}`,
  description:
    'Frequently asked questions about Phoenix Moving services, pricing, licensing, payments, and what to expect on moving day.',
  keywords:
    'moving FAQ, moving questions, Boston movers FAQ, moving cost, licensed movers',
  pathname: Astro.url.pathname,
  breadcrumbs: [
    { name: 'Home', path: '/' },
    { name: 'FAQ', path: '/faq' },
  ],
  ogImage: socialImageUrl,
  jsonLdExtra: [
    buildFaqJsonLd(
      Astro.url.pathname,
      faqs.map((faq) => ({
        question: faq.question,
        answer: stripHtmlForSchema(faq.answer),
      }))
    ),
  ],
});
---

<Layout {...seo} lcpPreload={lcpPreload}>
  <Hero2
    bgImage={heroBg}
    title="Frequently Asked Questions"
    subtitle="Answers to your questions about our moving services."
  />
  <FAQ1 />
  <RelatedServices
    links={getRelatedLinks(Astro.url.pathname)}
    class="defer-section"
  />
  <CTA1 class="defer-section" />
</Layout>
