---
import Layout from '@/layouts/Layout.astro';
import Container from '@/components/Container.astro';
import Section from '@/components/Section.astro';
import Process1 from '@/blocks/process/Process1.astro';
import FAQ1 from '@/blocks/faq/FAQ1.astro';
import { SITE } from '@/config/site';
import RelatedServices from '@/blocks/related/RelatedServices.astro';
import { fetchPageSeo } from '@/seo';
import { getRelatedLinks, getServiceFaqs } from '@/config/service-faqs';
import { servicePageJsonLd } from '@/seo/service-page-schema';
import SectionHeader from '@/components/SectionHeader.astro';
import BookFormFrame from '@/components/BookFormFrame.astro';
import Stats1 from '@/blocks/stats/Stats1.astro';
import MouseRepelParticles from '@/components/MouseRepelParticles.astro';

const pathname = Astro.url.pathname;
const pageFaqs = getServiceFaqs(pathname);
const seo = await fetchPageSeo(Astro.url, {
  title: `Book Your Move — Get a Free Moving Quote | ${SITE.businessName}`,
  description: `Book Boston movers online in minutes. Get a free, no-obligation moving quote from ${SITE.businessShortName} — licensed and insured crews serving Greater Boston.`,
  keywords:
    'book a move, moving quote, free moving estimate, schedule movers, Boston movers',
  pathname,
  breadcrumbs: [
    { name: 'Home', path: '/' },
    { name: 'Book Your Move', path: '/book' },
  ],
  jsonLdExtra: servicePageJsonLd(pathname, {
    name: `How to book your move with ${SITE.businessShortName}`,
    description:
      'Get a free quote, pick your date, and move with licensed Boston movers.',
  }),
});
---

<Layout {...seo}>
  <Section
    class="pt-28 md:pt-32 relative isolate overflow-hidden bg-linear-to-b from-muted/50 to-transparent"
    spacing="none"
  >
    <MouseRepelParticles />
    <Container>
      <SectionHeader
        label="Free Online Estimate"
        title="Book Your Move"
        subtitle="Get a free estimate in minutes — share your move details and get a fast, transparent quote with no obligation."
      />
      <BookFormFrame>
        <div id="phoenix-moving-calculator"></div>
      </BookFormFrame>
    </Container>
  </Section>

  <Process1 class="defer-section" />

  <Stats1 class="defer-section" />

  <RelatedServices links={getRelatedLinks(pathname)} class="defer-section" />

  <FAQ1 items={pageFaqs} class="defer-section" />
</Layout>

<script
  is:inline
  src="https://account.gophoenixmoving.com/calculator-embed.js"
  defer></script>
