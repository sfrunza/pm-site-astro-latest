---
import Layout from '@/layouts/Layout.astro';
import Container from '@/components/Container.astro';
import Section from '@/components/Section.astro';
import FeatureSteps from '@/blocks/feature/FeatureSteps.astro';
import FAQ1 from '@/blocks/faq/FAQ1.astro';
import Button from '@/components/starwind/button';
import { CircleCheckIcon, PhoneIcon, MailIcon } from '@/icons';
import { SITE } from '@/config/site';
import RelatedServices from '@/blocks/related/RelatedServices.astro';
import { fetchPageSeo } from '@/seo';
import { getRelatedLinks, getServiceFaqs } from '@/config/service-faqs';
import { servicePageJsonLd } from '@/seo/service-page-schema';
import SectionHeader from '@/components/SectionHeader.astro';

const pathname = Astro.url.pathname;
const pageFaqs = getServiceFaqs(pathname);
const seo = await fetchPageSeo(Astro.url, {
  title: 'Book Your Move — Get a Free Moving Quote | Phoenix Moving Boston',
  description:
    'Book Boston movers online in minutes. Get a free, no-obligation moving quote from Phoenix Moving — licensed and insured crews serving Greater Boston.',
  keywords:
    'book a move, moving quote, free moving estimate, schedule movers, Boston movers',
  pathname,
  breadcrumbs: [
    { name: 'Home', path: '/' },
    { name: 'Book Your Move', path: '/book' },
  ],
  jsonLdExtra: servicePageJsonLd(pathname, {
    name: 'How to book your move with Phoenix Moving',
    description:
      'Get a free quote, pick your date, and move with licensed Boston movers.',
  }),
});

const highlights = [
  'Free, no-obligation estimate',
  'Transparent pricing',
  'Licensed & insured',
  'Flexible scheduling',
];
---

<Layout {...seo}>
  {/* Page intro */}
  <Section class="pt-28 pb-10 md:pt-32 md:pb-12">
    <Container>
      <div class="mx-auto max-w-2xl text-center">
        <SectionHeader
          label="Free Online Estimate"
          title="Book Your Move"
          subtitle="Book Boston movers in minutes — share your move details and get a fast, transparent quote with no obligation."
        />
        <ul
          class="mt-8 flex flex-wrap items-center justify-center gap-2"
          aria-label="Why book with us"
        >
          {
            highlights.map((item) => (
              <li>
                <span class="bg-muted/50 text-foreground inline-flex items-center gap-1.5 rounded-full px-3 py-1.5 text-sm font-medium">
                  <CircleCheckIcon
                    class="text-primary size-4 shrink-0"
                    aria-hidden="true"
                  />
                  {item}
                </span>
              </li>
            ))
          }
        </ul>
      </div>
    </Container>
  </Section>

  {/* Booking form — centered focal section */}
  <Section class="pb-16 md:pb-20" aria-label="Booking form">
    <Container>
      <div class="mx-auto max-w-xl">
        <div class="booking-widget-container min-h-[580px] w-full"></div>

        <div
          class="text-muted-foreground mt-8 flex flex-col items-center gap-4 text-center text-sm sm:flex-row sm:justify-center sm:gap-6"
        >
          <span>Prefer to talk? We're happy to help.</span>
          <div class="flex flex-wrap items-center justify-center gap-3">
            <Button
              variant="outline"
              size="sm"
              href={`tel:${SITE.contactPhone}`}
            >
              <PhoneIcon />
              {SITE.contactPhone}
            </Button>
            <Button
              variant="ghost"
              size="sm"
              href={`mailto:${SITE.contactEmail}`}
            >
              <MailIcon />
              Email us
            </Button>
          </div>
        </div>
        <p class="text-muted-foreground mt-4 text-center text-xs">
          Licensed MDPU #{SITE.businessLicenses.MDPU} · US DOT #{
            SITE.businessLicenses.DOT
          }
        </p>
      </div>
    </Container>
  </Section>

  {/* Quick reassurance — compact, not a heavy stats band */}
  <Section class="border-y bg-muted/50 py-12">
    <Container>
      <dl
        class="mx-auto grid max-w-3xl gap-8 text-center sm:grid-cols-3 sm:gap-6"
      >
        <div class="space-y-1">
          <dt class="text-primary text-3xl font-bold tracking-tight">
            ~15 min
          </dt>
          <dd class="text-muted-foreground text-sm font-medium">
            To complete your quote
          </dd>
        </div>
        <div class="space-y-1">
          <dt class="text-primary text-3xl font-bold tracking-tight">4.98★</dt>
          <dd class="text-muted-foreground text-sm font-medium">
            From 240+ reviews
          </dd>
        </div>
        <div class="space-y-1">
          <dt class="text-primary text-3xl font-bold tracking-tight">$0</dt>
          <dd class="text-muted-foreground text-sm font-medium">
            Cost for your estimate
          </dd>
        </div>
      </dl>
    </Container>
  </Section>

  <FeatureSteps />

  <RelatedServices links={getRelatedLinks(pathname)} />
  <FAQ1 items={pageFaqs} />
</Layout>

<script
  is:inline
  src="https://crm-app-client-six.vercel.app/book-form-widget.js"
  defer></script>
